216:              
217:              /***********************************************************
218:              嶄僅捲暦痕方
219:              痕方兆各⦿AD_Init()
220:              痕方孔嬬⦿AD兜兵晒侃尖痕方
221:              秘笥歌方⦿
222:              竃笥歌方⦿
223:              姥    廣⦿及匯肝嬉蝕AD塋俯了ADON⇧俶决扮20uS參貧嘉嬬序秘AD寡劔
224:              			泌朔写殻會音購液ADON⇧夸音俶勣决扮
225:              ***********************************************************/
226:              void AD_Init() 
227:              {
228:              	/*********** ADCON0 ****************************
229:              		Bit7~Bit6  ADCS<1:0>:  AD廬算扮嶝僉夲了。
230:              			00=  F HSI /16
231:              			01=  F HSI /32
232:              			10=  F HSI /64
233:              			11=  F HSI /128
234:              		Bit5~Bit2  CHS<3:0>:  庁亭宥祇僉夲了。嚥ADCON1篠贋匂CHS4怏栽CHS<3:0>
235:              			CHS<4:0>: 
236:              			00000=  AN0
237:              			00001=  AN1
238:              			00010=  AN2
239:              			00011=  AN3
240:              			00100=  AN4
241:              			00101=  AN5
242:              			00110=  隠藻
243:              			00111=  隠藻
244:              			01000=  AN8
245:              			´ 
246:              			01101=  AN13
247:              			01110=  AN14
248:              			01111=  AN15
249:              			11111=  1.2V↙耕協歌深窮儿⇄
250:              			凪麿=  隠藻
251:              		Bit1  GO/DONE: AD廬算彜蓑了。
252:              			1=  AD廬算屎壓序佩。繍乎了崔1尼強AD廬算。輝AD廬算頼撹參朔⇧乎了喇啣周徭強賠巣。
253:              				輝GO/DONE了貫1延0賜ADIF貫0延1扮⇧俶崛富吉棋曾倖TAD扮寂⇧嘉嬬壅肝尼強AD廬算。
254:              			0=  AD廬算頼撹/賜音壓序佩嶄。
255:              		Bit0  ADON:  ADC聞嬬了。
256:              			1=  聞嬬ADC◉
257:              			0=  鋤峭ADC⇧音嶧債垢恬窮送。
258:              	*********************************************/
259:              	ADCON0 = 0X41;		//ADON蝕尼⇧AD寡劔扮寂僉葎FSYS/16
  02B5    3041    LDIA	0x41
  02B6    1683    SETB	0x3,5
  02B7    0095    LD	0x15,A
260:              	
261:              	/*********** ADCON1 ****************************
262:              		Bit7  ADFM:  AD廬算潤惚鯉塀僉夲了◉
263:              			1=  嘔斤馴◉
264:              			0=  恣斤馴。
265:              		Bit6  CHS4:  宥祇僉夲了
266:              		Bit5~Bit3  隆喘 
267:              		Bit2  LDO_EN:  坪何歌深窮儿聞嬬了。
268:              			1=  聞嬬ADC坪何LDO歌深窮儿◉
269:              				輝僉夲坪何LDO恬歌深窮儿扮⇧ADC恷寄嗤丼娼業葎8了。
270:              			0=  VDD恬葎ADC歌深窮儿。
271:              		Bit1~Bit0  LDO_SEL<1:0>:  歌深窮儿僉夲了
272:              			0X=  2.0V
273:              			10=  2.4V
274:              			11=  3.0V
275:              	*********************************************/
276:              	ADCON1 = 0;
  02B8    0196    CLR	0x16
  02B9    0008    RET
277:              }

  28          void adc()
  29          { 
  30   1        //VSP
  31   1        ADCON0 = 0x40;          //0100 0000 右对齐 AN12 1 0000
  32   1        ADCON1 = 0xC8;          //1100 1100 使能ADC  1100 32分频 AN12 通道 
  33   1        ADCON0 |= 1<<1;   
  34   1        while(ADCON0 & 0x02);
  35   1        AD_VspValueTemp = (ADRESH<<8) + ADRESL; 
  36   1        ADRESH = 0x00;
  37   1        ADRESL = 0x00;
  38   1        
  39   1        //VIN
  40   1        ADCON0 = 0xC0;          //1100 0000 右对齐 AN17 1 0001  //这里检测的是电池电压
  41   1        ADCON1 = 0xC1;          //1100 1011 使能ADC 32分频 AN17通道 
  42   1        ADCON0 |= 1<<1;   
  43   1        while(ADCON0 & 0x02);
  44   1        AD_VinValueTemp = (ADRESH<<8) + ADRESL; 
  45   1        ADRESH = 0x00;
  46   1        ADRESL = 0x00;
  47   1      
  48   1        //SC
  49   1        ADCON0 = 0xD0;          //1101 0000 右对齐 AN22
  50   1        ADCON1 = 0xC7;          //1100 1111 使能ADC 32分频 AN22通道 
  51   1        ADCON0 |= 1<<1;   
  52   1        while(ADCON0 & 0x02);
  53   1        AD_Op1oValueTemp = (ADRESH<<8) + ADRESL;  
  54   1        ADRESH = 0x00;

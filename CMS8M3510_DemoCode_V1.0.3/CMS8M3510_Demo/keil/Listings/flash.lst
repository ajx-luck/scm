  87           ** \param [in] Addr: 16bit   FLASH_CODE_ADDR: 0x00~0x3FFF; 
  88           **       Data: 8bit
  89           ** \return  none
  90           ** \note  
  91          *****************************************************************************/
  92          void FLASH_Write_CodeArea( uint16_t Addr, uint8_t Data)
  93          {
  94   1        MDATA = Data;
  95   1        MADRL = Addr;
  96   1        MADRH = Addr>>8;
  97   1        
  98   1        if(1==EA)     
  99   1        {
 100   2          EA=0;   //在CPU_WAITCLOCK选择1T的模式时，在EA=0后必须加nop,选择多T时不加。
 101   2          _nop_();    
 102   2          MCTRL = FLASH_WRITE ;   //操作FLASH期间不允许被打断
 103   2          _nop_();
 104   2          _nop_();
 105   2          _nop_();
 106   2          _nop_();
 107   2          _nop_();
 108   2          _nop_();  
 109   2          while(MCTRL & 0x01);
 110   2          EA=1;
 111   2        }
 112   1        else
 113   1        {
 114   2          MCTRL = FLASH_WRITE ; 
 115   2          _nop_();

 155          /*****************************************************************************
 156           ** \brief   SYS_EnableWDTReset
 157           **      使能WDT复位System
 158           ** \param [in] none
 159           **
 160           ** \return none
 161           ** \note
 162           *****************************************************************************/
 163          void SYS_EnableWDTReset(void)
 164          {
 165   1        if(EA==1) //操作TA时序时不允许被打断，因而需要关闭中断
 166   1        {
 167   2          EA=0;   //在CPU_WAITCLOCK选择1T的模式时，在EA=0后必须加nop,选择多T时不加。
 168   2          _nop_();
 169   2          TA = 0xAA;
 170   2          TA = 0x55;
 171   2          WDCON |= WDT_WDCON_WDTRE_Msk;
 172   2          EA=1;
 173   2        }
 174   1        else
 175   1        {
 176   2          TA = 0xAA;
 177   2          TA = 0x55;
C51 COMPILER V9.01   SYSTEM                                                                11/21/2025 10:01:11 PAGE 4   

 178   2          WDCON |= WDT_WDCON_WDTRE_Msk;
 179   2        }
 180   1      }

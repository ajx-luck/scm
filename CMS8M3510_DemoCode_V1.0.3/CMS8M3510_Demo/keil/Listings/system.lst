 417          /*****************************************************************************
 418           ** \brief   SYS_ConfigWUTCLK
 419           **     设置定时唤醒时钟
 420           ** \param [in] clkdiv: (1)WUT_CLK_DIV_1 
 421           **           (2)WUT_CLK_DIV_8
 422           **           (2)WUT_CLK_DIV_32
 423          **            (2)WUT_CLK_DIV_256
 424           ** \return none
 425           ** \note   
C51 COMPILER V9.01   SYSTEM                                                                11/21/2025 10:01:11 PAGE 8   

 426           *****************************************************************************/
 427          void SYS_ConfigWUTCLK(uint8_t clkdiv )
 428          {
 429   1        uint8_t Temp=0;
 430   1        
 431   1        Temp = WUTCRH;
 432   1        Temp &= ~(0x3<<4);
 433   1        Temp |= (clkdiv<<4);
 434   1        WUTCRH = Temp;  
 435   1      }
 436          
 437          /*****************************************************************************
 438           ** \brief   SYS_ConfigWUTTime
 439           **     设置定时唤醒时间
 440           ** \param [in] time: 12it（0x0 ~ 0xFFF）
 441           ** \return none
 442           ** \note   
 443           *****************************************************************************/
 444          void SYS_ConfigWUTTime(uint16_t time )
 445          {
 446   1        uint8_t Temp=0;
 447   1        
 448   1        Temp = WUTCRH;
 449   1        Temp &=0xf0;
 450   1        Temp |= time>>8;
 451   1        WUTCRH = Temp;
 452   1        
 453   1        WUTCRL = time;
 454   1      }

189:              void pwm4Stop()
190:              {
191:              	PWMCON0 &= 0XEF;
  048C    1215    CLRB	0x15,4
192:              	RB2 = 0;
  048D    1106    CLRB	0x6,2
  048E    0008    RET
193:              
194:              }

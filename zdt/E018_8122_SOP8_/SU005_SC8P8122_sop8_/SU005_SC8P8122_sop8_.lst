218:              void pwm43Stop()
219:              {
220:              	PWMCON0 &= 0XE7;
  0482    30E7    LDIA	0xE7
  0483    0595    ANDR	0x15
221:              	PORTB &= 0xEB;
  0484    30EB    LDIA	0xEB
  0485    0586    ANDR	0x6
  0486    0008    RET

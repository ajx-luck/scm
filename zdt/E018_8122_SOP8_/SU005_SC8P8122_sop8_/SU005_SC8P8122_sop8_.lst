  038D    018B    CLR	0xB
265:              		PIE1 = 0;
  038E    018E    CLR	0xE
266:              		PIE2 = 0;
  038F    1703    SETB	0x3,6
  0390    0190    CLR	0x10
267:              		PIR1 = 0;
  0391    1303    CLRB	0x3,6
  0392    018D    CLR	0xD

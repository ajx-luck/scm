280:              			WPUB0 = 1;	//上拉			
281:              			RBIF = 0;	//清标志
282:              			RBIE = 1;	//允许PB口电平变化中断
283:              			
284:              			PORTB;		//读一次PB口			
285:              ************************************/	
286:              
287:              		//进入休眠模式,触摸允许唤醒的按键后恢复正常工作
288:              		SystemEnterSleep();
  039B    2102    CALL	0x102
289:              		if(RBIF) 
  039C    1C0B    SNZB	0xB,0
  039D    2BA0    JP	0x3A0
290:              		{
291:              			RBIF = 0;
  039E    100B    CLRB	0xB,0
292:              			PORTB;

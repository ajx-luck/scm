236:              void interrupt Isr_Timer()
237:              {
238:              	if(TMR2IF)				//若只使能了一个中断源,可以略去判断
  03D0    1283    CLRB	0x3,5
  03D1    1303    CLRB	0x3,6
  03D2    1C8D    SNZB	0xD,1
  03D3    2BDD    JP	0x3DD
239:              	{
240:              		TMR2IF = 0;
  03D4    108D    CLRB	0xD,1
241:              		if(++MainTime >= 32)	//需根据你选择的触摸路数和触摸电容选择扫描一次按键的时间
  03D5    3020    LDIA	0x20
  03D6    0ABC    INCR	0x3C
  03D7    023C    SUBA	0x3C
  03D8    1C03    SNZB	0x3,0
  03D9    2BDE    JP	0x3DE
242:              		{						//可根据测量CAP口的电容充电时间判断扫描一次需要的时间
243:              			MainTime = 0;
  03DA    01BC    CLR	0x3C
244:              			B_MainLoop = 1;
  03DB    1778    SETB	0x78,6
  03DC    2BDE    JP	0x3DE
245:              		}
246:              	}
247:              	else
248:              	{
249:              		PIR1 = 0;
  03DD    018D    CLR	0xD
  03DE    0871    LD	A,0x71
  03DF    008A    LD	0xA,A
  03E0    0E70    SWAPA	0x70
  03E1    0083    LD	0x3,A
  03E2    0EFE    SWAPR	0x7E
  03E3    0E7E    SWAPA	0x7E
  03E4    0009    RETI
250:              	}
251:              	
252:              }

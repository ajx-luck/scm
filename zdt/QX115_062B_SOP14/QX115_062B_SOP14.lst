932:              /***********************************************
933:              函数名称：Sleep_Mode
934:              函数功能：进入休眠模式
935:              入口参数：无
936:              出口参数：无
937:              备注：
938:              ************************************************/
939:              void Sleep_Mode()
940:              {
941:              	INTCON = 0;		
  0403    018B    CLR	0xB
942:              	
943:              	OPTION_REG = 0;
  0404    0181    CLR	0x1
944:              
945:              	TRISA = 0x17; 		//关闭所有输出，RA0口做唤醒输入
  0405    3017    LDIA	0x17
  0406    1683    SETB	0x3,5
  0407    0085    LD	0x5,A
946:              	WPUA  = 0B00000000;			//RA0 开上拉电阻
  0408    0188    CLR	0x8
947:              	PORTA = 0x00;
  0409    0186    CLR	0x6
948:              	TRISB = 0B00000100;			//关闭所有输出，RB3口做唤醒输入
  040A    3004    LDIA	0x4
  040B    1283    CLRB	0x3,5
  040C    0085    LD	0x5,A
949:              	PORTB = 0B00000000;
  040D    0186    CLR	0x6
950:              	WPUB  = 0B00000100;			//RB2 开上拉电阻
  040E    0088    LD	0x8,A
951:                 			
952:                 	ADCON0 = 0;					//关闭所有模块
  040F    1683    SETB	0x3,5
  0410    0195    CLR	0x15
953:              	ADCON1 = 0;
  0411    0196    CLR	0x16
954:              	
955:              	PWMCON0 = 0;
  0412    1283    CLRB	0x3,5
  0413    0195    CLR	0x15
956:              		
957:              	OSCCON = 0X70;				//配置振荡为8M,关闭WDT，需注意芯片工程选项里WDT必须选为DISABLE,否则无法软件关掉WDT
  0414    3070    LDIA	0x70
  0415    0094    LD	0x14,A
958:              	
959:              	IOCA = 0x10;			//允许RA1的IO电平变化中断
  0416    3010    LDIA	0x10
  0417    1683    SETB	0x3,5
  0418    0089    LD	0x9,A
960:              	IOCB = 0B00000100;			//允许RB3的IO口电平变化中断
  0419    3004    LDIA	0x4
  041A    1283    CLRB	0x3,5
  041B    0089    LD	0x9,A
961:              	
962:              	RAIE = 1;					//允许PORTA的IO电平变化中断
  041C    158E    SETB	0xE,3
963:              	PEIE = 1;					//要用RORTA中断唤醒，则PEIE必须设为1
  041D    170B    SETB	0xB,6
964:              	RBIE = 1;					//允许PORTB电平变化中断
  041E    158B    SETB	0xB,3
965:              	GIE = 0;					//唤醒后执行SLEEP后程序;
  041F    138B    CLRB	0xB,7
966:              	
967:              	PIE1 &= 0X08;				//关闭不需要的中断
  0420    3008    LDIA	0x8
  0421    058E    ANDR	0xE
968:              	PIR1 = 0;					//必须清不需要的中断标志位
  0422    018D    CLR	0xD
969:              	INTCON &= 0XC8;				//必须清不需要的中断标志位
  0423    30C8    LDIA	0xC8
  0424    058B    ANDR	0xB
970:              
971:              	PORTA;						//读PORTA值并锁存,用电平变化中断必须执行这一步
  0425    1683    SETB	0x3,5
  0426    0806    LD	A,0x6
972:              	RAIF = 0;					//清PORTA中断标志位
  0427    1283    CLRB	0x3,5
  0428    118D    CLRB	0xD,3
973:              	PORTB;						//读PORTB值并锁存	
  0429    0806    LD	A,0x6
974:              	RBIF = 0;					//清PORTB中断标志位		
  042A    100B    CLRB	0xB,0
  042B    0064    CLRWDT
  042C    0063    STOP
  042D    0000    NOP
  042E    0064    CLRWDT
  042F    0000    NOP
  0430    0000    NOP
  0431    0000    NOP
  0432    0000    NOP
  0433    0000    NOP
975:              	asm("clrwdt");
976:              
977:              	asm("sleep");				//进入休眠模式
978:              	
979:              	asm("nop");
980:              	asm("clrwdt");
981:              	asm("nop");
982:              	asm("nop");
983:              	asm("nop");
984:              	asm("nop");
985:              	asm("nop");
986:              	if(RAIF)  RAIF = 0;			//清中断标志
  0434    1283    CLRB	0x3,5
  0435    198D    SZB	0xD,3
  0436    118D    CLRB	0xD,3
987:              	if(RBIF)  RBIF = 0;			//清中断标志
  0437    180B    SZB	0xB,0
  0438    100B    CLRB	0xB,0
988:              	if(TMR2IF) TMR2IF = 0;
  0439    188D    SZB	0xD,1
  043A    108D    CLRB	0xD,1
989:              	IOCA = 0B00000000;			//允许RA1的IO电平变化中断
  043B    1683    SETB	0x3,5
  043C    0189    CLR	0x9
990:              	IOCB = 0B00000000;			//允许RB3的IO口电平变化中断
  043D    1283    CLRB	0x3,5
  043E    0189    CLR	0x9
991:              	Init_System();
  043F    250A    CALL	0x50A
992:              	AD_Init();
  0440    2DBA    JP	0x5BA
993:              }

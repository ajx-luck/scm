767:              	    		{
768:              	    			countHalfFull = 0;
  02A2    01CF    CLR	0x4F
769:              					protectFlag = 2;
  02A3    00CE    LD	0x4E,A
  02A4    0008    RET
770:              	    		}
771:              	    	}
772:              	    	else
773:              	    	{
774:              	    		countHalfFull = 0;
  02A5    01CF    CLR	0x4F
775:              	    	}
776:              	    }
777:              	}
  02A6    0008    RET
778:              	else
779:              	{
780:              		ADCON0 = 0;						//如果转换没有完成，需初始化ADCON0,1
  02A7    1683    SETB	0x3,5
  02A8    0195    CLR	0x15
781:              		ADCON1 = 0;				
  02A9    0196    CLR	0x16
782:              		__delay_us(100);				//延时100us(编译器内置函数)
  02AA    3085    LDIA	0x85
  02AB    00F4    LD	0x74,A
  02AC    0BF4    SZDECR	0x74
  02AD    2AAC    JP	0x2AC
  02AE    0008    RET
783:              	}
784:              }

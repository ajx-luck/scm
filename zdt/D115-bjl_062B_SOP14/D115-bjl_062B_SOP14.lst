1:                // byte unsigned modulus
2:                
3:                unsigned char
4:                __lbmod(unsigned char dividend, unsigned char divisor)
  03AE    00F4    LD	0x74,A
  03AF    3008    LDIA	0x8
  03B0    00F5    LD	0x75,A
  03B1    01F6    CLR	0x76
  03B2    0874    LD	A,0x74
  03B3    00F3    LD	0x73,A
  03B4    3007    LDIA	0x7
  03B5    1003    CLRB	0x3,0
  03B6    0CF3    RRCR	0x73
  03B7    3EFF    ADDIA	0xFF
  03B8    1003    CLRB	0x3,0
  03B9    1D03    SNZB	0x3,2
  03BA    2BB6    JP	0x3B6
  03BB    0D76    RLCA	0x76
  03BC    0473    ORA	0x73
  03BD    00F6    LD	0x76,A
  03BE    1003    CLRB	0x3,0
  03BF    0DF4    RLCR	0x74
  03C0    0872    LD	A,0x72
  03C1    0276    SUBA	0x76
  03C2    1C03    SNZB	0x3,0
  03C3    2BC6    JP	0x3C6
  03C4    0872    LD	A,0x72
  03C5    02F6    SUBR	0x76
  03C6    0BF5    SZDECR	0x75
  03C7    2BB2    JP	0x3B2
  03C8    0876    LD	A,0x76
  03C9    0008    RET
5:                {
6:                	unsigned char	rem;
7:                	unsigned char	counter;
8:                
9:                	counter = 8;
10:               	rem = 0;
11:               	do {
12:               		rem = (rem << 1) | (dividend >> 7);
13:               		dividend <<= 1;
14:               		if(divisor <= rem)
15:               			rem -= divisor;
16:               	} while(--counter != 0);
17:               	return rem;
18:               }

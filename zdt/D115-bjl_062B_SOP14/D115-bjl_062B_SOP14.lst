780:              /**********************************************************
781:              函数名称：AD_Sample
782:              函数功能：AD检测
783:              入口参数：adch - 检测通道
784:              出口参数：无
785:              备    注：采样通道需自行设置为输入口
786:              	      采样10次,取中间八次的平均值为采样结果存于adresult中
787:              
788:              	      adch 为输入AD通道 0-15，31
789:                           31  检测内部1.2V
790:              	
791:               		  adldo =5,开启内部LDO 2V 作为ADC 参考
792:               		  adldo =6,开启内部LDO 2.4V 作为ADC 参考
793:              		  adldo =7,开启内部LDO 3V 作为ADC 参考
794:               		  adldo =0,VDD 作为ADC 参考
795:               		  AD转换结果左对齐
796:               		  ADC参考电压从VDD切换到LDO时需要延时100us以上，才能进行AD转换
797:              **********************************************************/
798:              unsigned char ADC_Sample(unsigned char adch, unsigned char adldo) 
  0016    00C5    LD	0x45,A
799:              {
800:              	volatile unsigned long adsum = 0;
801:              	volatile unsigned int admin = 0, admax = 0;
  0017    20EE    CALL	0xEE
802:              	volatile unsigned int ad_temp = 0;
  0018    01CF    CLR	0x4F
  0019    01D0    CLR	0x50
803:              
804:              	if ((!LDO_EN) && (adldo & 0x04) ) 
  001A    1683    SETB	0x3,5
  001B    1D16    SNZB	0x16,2
  001C    1D72    SNZB	0x72,2
  001D    2825    JP	0x25
805:              	{
806:              								//如果AD参考从VDD换到内部LDO，需要延时100US以上
807:              		ADCON1 = adldo;			//左对齐,AD值取12位
  001E    0872    LD	A,0x72
  001F    0096    LD	0x16,A
808:              		__delay_us(100);		//IDE内置延时函数，延时100us
  0020    3085    LDIA	0x85
  0021    00F3    LD	0x73,A
  0022    0BF3    SZDECR	0x73
  0023    2822    JP	0x22
809:              	} 
  0024    2827    JP	0x27
810:              	else
811:              		ADCON1 = adldo;			//如果ADCON1.7(ADFM)=1为右对齐，,AD值取10位
  0025    0872    LD	A,0x72
  0026    0096    LD	0x16,A
812:              
813:              	if(adch & 0x10) 
  0027    1283    CLRB	0x3,5
  0028    1E45    SNZB	0x45,4
  0029    282F    JP	0x2F
814:              	{
815:              		CHS4 = 1;
  002A    1683    SETB	0x3,5
  002B    1716    SETB	0x16,6
816:              		adch &= 0x0f;
  002C    300F    LDIA	0xF
  002D    1283    CLRB	0x3,5
  002E    05C5    ANDR	0x45
817:              	}
818:              	unsigned char i = 0;
819:              	for (i = 0; i < 10; i++) 
  002F    01C6    CLR	0x46
820:              	{
821:              		ADCON0 = (unsigned char)(0X41 | (adch << 2));	//16分频，如果主频为16M，则必须选16分频或以上
  0030    0845    LD	A,0x45
  0031    00F3    LD	0x73,A
  0032    3001    LDIA	0x1
  0033    1003    CLRB	0x3,0
  0034    0DF3    RLCR	0x73
  0035    3EFF    ADDIA	0xFF
  0036    1003    CLRB	0x3,0
  0037    1D03    SNZB	0x3,2
  0038    2834    JP	0x34
  0039    0D73    RLCA	0x73
  003A    3841    ORIA	0x41
  003B    1683    SETB	0x3,5
  003C    0095    LD	0x15,A
  003D    0000    NOP
  003E    0000    NOP
  003F    0000    NOP
  0040    0000    NOP
822:              		asm("nop");
823:              		asm("nop");
824:              		asm("nop");
825:              		asm("nop");				//选择通道后需延时1uS以上
826:              		GODONE = 1;				//开始转换
  0041    1683    SETB	0x3,5
  0042    1495    SETB	0x15,1
827:              
828:              		unsigned char j = 0;
  0043    1283    CLRB	0x3,5
  0044    01C4    CLR	0x44
829:              		while (GODONE) 
  0045    1683    SETB	0x3,5
  0046    1C95    SNZB	0x15,1
  0047    2850    JP	0x50
830:              		{
831:              			__delay_us(2);		//延时2us(编译器内置函数)
  0048    2849    JP	0x49
  0049    284A    JP	0x4A
  004A    284B    JP	0x4B
  004B    284C    JP	0x4C
832:              
833:              			if (0 == (--j))		//延时0.5ms仍没有AD转换结束，跳出程序
  004C    1283    CLRB	0x3,5
  004D    0BC4    SZDECR	0x44
  004E    2845    JP	0x45
834:              			return 0;
  004F    3400    RET	0x0
835:              		}
836:              
837:              		ad_temp = (unsigned int)((ADRESH << 4) + (ADRESL >> 4));	//计算12位AD值
  0050    0819    LD	A,0x19
  0051    1283    CLRB	0x3,5
  0052    00CF    LD	0x4F,A
  0053    01D0    CLR	0x50
  0054    0ECF    SWAPR	0x4F
  0055    0ED0    SWAPR	0x50
  0056    30F0    LDIA	0xF0
  0057    05D0    ANDR	0x50
  0058    084F    LD	A,0x4F
  0059    390F    ANDIA	0xF
  005A    04D0    ORR	0x50
  005B    30F0    LDIA	0xF0
  005C    05CF    ANDR	0x4F
  005D    1683    SETB	0x3,5
  005E    0E18    SWAPA	0x18
  005F    390F    ANDIA	0xF
  0060    1283    CLRB	0x3,5
  0061    07CF    ADDR	0x4F
  0062    1803    SZB	0x3,0
  0063    0AD0    INCR	0x50
838:              
839:              		if (0 == admax) 
  0064    084D    LD	A,0x4D
  0065    044E    ORA	0x4E
  0066    1D03    SNZB	0x3,2
  0067    286A    JP	0x6A
840:              		{
841:              			admax = ad_temp;
  0068    20F7    CALL	0xF7
  0069    287C    JP	0x7C
842:              			admin = ad_temp;
843:              		} 
844:              		else if (ad_temp > admax)
  006A    0850    LD	A,0x50
  006B    024E    SUBA	0x4E
  006C    1D03    SNZB	0x3,2
  006D    2870    JP	0x70
  006E    084F    LD	A,0x4F
  006F    024D    SUBA	0x4D

594:              /**********************************************************
595:              函数名称：Init_System
596:              函数功能：系统初始化
597:              入口参数：无
598:              出口参数：无
599:              备    注：
600:              **********************************************************/
601:              void Init_System() 
  036D    0000    NOP
  036E    0064    CLRWDT
602:              {
603:              	asm("nop");
604:              	asm("clrwdt");
605:              	OPTION_REG = 0;					//预分频给TMR0 ，Timer0使用内部时钟Focs/4，预分频比为1:2
  036F    1283    CLRB	0x3,5
  0370    0181    CLR	0x1
  0371    0064    CLRWDT
606:              	asm("clrwdt");
607:              	OSCCON = 0X72;					//内部振荡器8M
  0372    3072    LDIA	0x72
  0373    1283    CLRB	0x3,5
  0374    0094    LD	0x14,A
608:              
609:              	WPUA = 0B00000000;				//配置上拉，1为使能上拉
  0375    1683    SETB	0x3,5
  0376    0188    CLR	0x8
610:              	WPDA = 0x00;					//RA1开下拉
  0377    0187    CLR	0x7
611:              	WPUB = 0x10;
  0378    3010    LDIA	0x10
  0379    1283    CLRB	0x3,5
  037A    0088    LD	0x8,A
612:              
613:              	TRISA = 0x03;				//配置IO状态，0为输出，1为输入
  037B    3003    LDIA	0x3
  037C    1683    SETB	0x3,5
  037D    0085    LD	0x5,A
614:              	TRISB = 0x14;
  037E    3014    LDIA	0x14
  037F    1283    CLRB	0x3,5
  0380    0085    LD	0x5,A
615:              
616:              	PORTA = 0X3C;
  0381    303C    LDIA	0x3C
  0382    1683    SETB	0x3,5
  0383    0086    LD	0x6,A
617:              	PORTB = 0X03;
  0384    3003    LDIA	0x3
  0385    1283    CLRB	0x3,5
  0386    0086    LD	0x6,A
618:              
619:              //---------------------------------------
620:              //125us中断初始化
621:              	PR2 = 249;					//设定Timer初始值，定时周期是250*2/8M=62.5uS
  0387    30F9    LDIA	0xF9
  0388    0091    LD	0x11,A
622:              	TMR2IF = 0;
  0389    108D    CLRB	0xD,1
623:              	TMR2IE = 1;					//使能Timer2溢出中断
  038A    148E    SETB	0xE,1
624:              
625:              	T2CON = 0B00000100;			//开启Timer2,设置TMR2的分频比为1:1
  038B    3004    LDIA	0x4
  038C    0093    LD	0x13,A
626:              	INTCON = 0XC0;				//开启总中断
  038D    30C0    LDIA	0xC0
  038E    008B    LD	0xB,A
  038F    0008    RET
627:              }

629:              /***********************************************************
630:              中断服务函数
631:              函数名称：AD_Init()
632:              函数功能：AD初始化处理函数
633:              入口参数：
634:              出口参数：
635:              备    注：第一次打开AD允许位ADON，需延时20uS以上才能进入AD采样
636:              			如后继程序不关闭ADON，则不需要延时
637:              ***********************************************************/
638:              void AD_Init() 
639:              {
640:              	/*********** ADCON0 ****************************
641:              		Bit7~Bit6  ADCS<1:0>:  AD转换时钟选择位。
642:              			00=  F HSI /16
643:              			01=  F HSI /32
644:              			10=  F HSI /64
645:              			11=  F HSI /128
646:              		Bit5~Bit2  CHS<3:0>:  模拟通道选择位。与ADCON1寄存器CHS4组合CHS<3:0>
647:              			CHS<4:0>: 
648:              			00000=  AN0
649:              			00001=  AN1
650:              			00010=  AN2
651:              			00011=  AN3
652:              			00100=  AN4
653:              			00101=  AN5
654:              			00110=  保留
655:              			00111=  保留
656:              			01000=  AN8
657:              			… 
658:              			01101=  AN13
659:              			01110=  AN14
660:              			01111=  AN15
661:              			11111=  1.2V（固定参考电压）
662:              			其他=  保留
663:              		Bit1  GO/DONE: AD转换状态位。
664:              			1=  AD转换正在进行。将该位置1启动AD转换。当AD转换完成以后，该位由硬件自动清零。
665:              				当GO/DONE位从1变0或ADIF从0变1时，需至少等待两个TAD时间，才能再次启动AD转换。
666:              			0=  AD转换完成/或不在进行中。
667:              		Bit0  ADON:  ADC使能位。
668:              			1=  使能ADC；
669:              			0=  禁止ADC，不消耗工作电流。
670:              	*********************************************/
671:              	ADCON0 = 0X41;		//ADON开启，AD采样时间选为FSYS/16
  0422    3041    LDIA	0x41
  0423    1683    SETB	0x3,5
  0424    0095    LD	0x15,A
672:              	
673:              	/*********** ADCON1 ****************************
674:              		Bit7  ADFM:  AD转换结果格式选择位；
675:              			1=  右对齐；
676:              			0=  左对齐。
677:              		Bit6  CHS4:  通道选择位
678:              		Bit5~Bit3  未用 
679:              		Bit2  LDO_EN:  内部参考电压使能位。
680:              			1=  使能ADC内部LDO参考电压；
681:              				当选择内部LDO作参考电压时，ADC最大有效精度为8位。
682:              			0=  VDD作为ADC参考电压。
683:              		Bit1~Bit0  LDO_SEL<1:0>:  参考电压选择位
684:              			0X=  2.0V
685:              			10=  2.4V
686:              			11=  3.0V
687:              	*********************************************/
688:              	ADCON1 = 0;
  0425    0196    CLR	0x16
689:              	ANSEL0 = 0X03;	
  0426    3003    LDIA	0x3
  0427    0093    LD	0x13,A
  0428    0008    RET
690:              }
691:              
692:              
693:              void pwmInit()
694:              {
695:              		PWMCON1 = 0B00000000;	//PWM选择D组，死区2禁止，死区1使能，死区时钟源为Fosc/4
  03FE    0196    CLR	0x16
696:              		PWMTH = 0X00;			//周期选择为0FF，则周期为（255+1）*1/8M，周期的时钟分频在PWMCON0选择
  03FF    0198    CLR	0x18
697:              		PWMTL = 100;			//PWM 周期=[PWMT+1]*Tosc*(CLKDIV 分频值)
  0400    3064    LDIA	0x64
  0401    0097    LD	0x17,A
698:              		
699:              		
700:              		PWMD23H = 0;			//配置PWM1,PWM2的占空比，该值不能超过周期，否者为100%输出
  0402    1683    SETB	0x3,5
  0403    019E    CLR	0x1E
701:              		PWMD2L = 50;			//互补模式，PWM1的占空比与PWM0互补，和设置值无关
  0404    3032    LDIA	0x32
  0405    009B    LD	0x1B,A
702:              		PWM23DT = 0X00;			//死区设为2uS，计算为（3+1）*1/8M*4
  0406    019D    CLR	0x1D
703:              
704:              		PWMCON0 = 0X64;			//打开PWM3 分频比为8
  0407    3064    LDIA	0x64
  0408    1283    CLRB	0x3,5
  0409    0095    LD	0x15,A
705:              		PWMCON2 =0X00;			//PWM4输出反向
  040A    019D    CLR	0x1D
  040B    0008    RET
706:              }
707:              
708:              void pwmStop()
709:              {
710:              	PWMCON0 &= 0XFB;
  0429    1115    CLRB	0x15,2
711:              	RB3 = 0;
  042A    1186    CLRB	0x6,3
  042B    0008    RET
712:              }

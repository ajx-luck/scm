715:              /***********************************************
716:              函数名称：Sleep_Mode
717:              函数功能：进入休眠模式
718:              入口参数：无
719:              出口参数：无
720:              备注：
721:              ************************************************/
722:              void Sleep_Mode()
723:              {
724:              	INTCON = 0;		
  0292    018B    CLR	0xB
725:              	
726:              	OPTION_REG = 0;
  0293    0181    CLR	0x1
727:              
728:              	TRISA = 0x03; 		//关闭所有输出，RA0口做唤醒输入
  0294    3003    LDIA	0x3
  0295    1683    SETB	0x3,5
  0296    0085    LD	0x5,A
729:              	WPUA  = 0B00000000;			//RA0 开上拉电阻
  0297    0188    CLR	0x8
730:              	PORTA = 0x3C;
  0298    303C    LDIA	0x3C
  0299    0086    LD	0x6,A
731:              	TRISB = 0x14;			//关闭所有输出，RB3口做唤醒输入
  029A    3014    LDIA	0x14
  029B    1283    CLRB	0x3,5
  029C    0085    LD	0x5,A
732:              	PORTB = 0x03;
  029D    3003    LDIA	0x3
  029E    0086    LD	0x6,A
733:              	WPUB  = 0x10;			//RB2 开上拉电阻
  029F    3010    LDIA	0x10
  02A0    0088    LD	0x8,A
734:                 			
735:                 	ADCON0 = 0;					//关闭所有模块
  02A1    1683    SETB	0x3,5
  02A2    0195    CLR	0x15
736:              	ADCON1 = 0;
  02A3    0196    CLR	0x16
737:              	
738:              	PWMCON0 = 0;
  02A4    1283    CLRB	0x3,5
  02A5    0195    CLR	0x15
739:              		
740:              	OSCCON = 0X70;				//配置振荡为8M,关闭WDT，需注意芯片工程选项里WDT必须选为DISABLE,否则无法软件关掉WDT
  02A6    3070    LDIA	0x70
  02A7    0094    LD	0x14,A
741:              	
742:              	IOCA = 0B00000000;			//允许RA1的IO电平变化中断
  02A8    1683    SETB	0x3,5
  02A9    0189    CLR	0x9
743:              	IOCB = 0x14;			//允许RB3的IO口电平变化中断
  02AA    3014    LDIA	0x14
  02AB    1283    CLRB	0x3,5
  02AC    0089    LD	0x9,A
744:              	
745:              	RAIE = 1;					//允许PORTA的IO电平变化中断
  02AD    158E    SETB	0xE,3
746:              	PEIE = 1;					//要用RORTA中断唤醒，则PEIE必须设为1
  02AE    170B    SETB	0xB,6
747:              	RBIE = 1;					//允许PORTB电平变化中断
  02AF    158B    SETB	0xB,3
748:              	GIE = 0;					//唤醒后执行SLEEP后程序;
  02B0    138B    CLRB	0xB,7
749:              	
750:              	PIE1 &= 0X08;				//关闭不需要的中断
  02B1    3008    LDIA	0x8
  02B2    058E    ANDR	0xE
751:              	PIR1 = 0;					//必须清不需要的中断标志位
  02B3    018D    CLR	0xD
752:              	INTCON &= 0XC8;				//必须清不需要的中断标志位
  02B4    30C8    LDIA	0xC8
  02B5    058B    ANDR	0xB
753:              
754:              	PORTA;						//读PORTA值并锁存,用电平变化中断必须执行这一步
  02B6    1683    SETB	0x3,5
  02B7    0806    LD	A,0x6
755:              	RAIF = 0;					//清PORTA中断标志位
  02B8    1283    CLRB	0x3,5
  02B9    118D    CLRB	0xD,3
756:              	PORTB;						//读PORTB值并锁存	
  02BA    0806    LD	A,0x6
757:              	RBIF = 0;					//清PORTB中断标志位		
  02BB    100B    CLRB	0xB,0
  02BC    0064    CLRWDT
  02BD    0063    STOP
  02BE    0000    NOP
  02BF    0064    CLRWDT
  02C0    0000    NOP
  02C1    0000    NOP
  02C2    0000    NOP
  02C3    0000    NOP
  02C4    0000    NOP
758:              	asm("clrwdt");
759:              
760:              	asm("sleep");				//进入休眠模式
761:              	
762:              	asm("nop");
763:              	asm("clrwdt");
764:              	asm("nop");
765:              	asm("nop");
766:              	asm("nop");
767:              	asm("nop");
768:              	asm("nop");
769:              	if(RAIF)  RAIF = 0;			//清中断标志
  02C5    1283    CLRB	0x3,5
  02C6    198D    SZB	0xD,3
  02C7    118D    CLRB	0xD,3
770:              	if(RBIF)  RBIF = 0;			//清中断标志
  02C8    180B    SZB	0xB,0
  02C9    100B    CLRB	0xB,0
771:              	if(TMR2IF) TMR2IF = 0;
  02CA    188D    SZB	0xD,1
  02CB    108D    CLRB	0xD,1
772:              	IOCA = 0B00000000;			//允许RA1的IO电平变化中断
  02CC    1683    SETB	0x3,5
  02CD    0189    CLR	0x9
773:              	IOCB = 0B00000000;			//允许RB3的IO口电平变化中断
  02CE    1283    CLRB	0x3,5
  02CF    0189    CLR	0x9
774:              	Init_System();
  02D0    236D    CALL	0x36D
775:              	AD_Init();
  02D1    2C22    JP	0x422
776:              }

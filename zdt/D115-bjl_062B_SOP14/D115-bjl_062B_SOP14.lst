1:                // byte unsigned division
2:                
3:                unsigned char
4:                __lbdiv(unsigned char dividend, unsigned char divisor)
  03CA    00F3    LD	0x73,A
  03CB    01F5    CLR	0x75
  03CC    0872    LD	A,0x72
  03CD    1903    SZB	0x3,2
  03CE    2BE3    JP	0x3E3
  03CF    01F4    CLR	0x74
  03D0    0AF4    INCR	0x74
  03D1    1BF2    SZB	0x72,7
  03D2    2BD6    JP	0x3D6
  03D3    1003    CLRB	0x3,0
  03D4    0DF2    RLCR	0x72
  03D5    2BD0    JP	0x3D0
  03D6    1003    CLRB	0x3,0
  03D7    0DF5    RLCR	0x75
  03D8    0872    LD	A,0x72
  03D9    0273    SUBA	0x73
  03DA    1C03    SNZB	0x3,0
  03DB    2BE0    JP	0x3E0
  03DC    0872    LD	A,0x72
  03DD    02F3    SUBR	0x73
  03DE    1475    SETB	0x75,0
  03DF    1003    CLRB	0x3,0
  03E0    0CF2    RRCR	0x72
  03E1    0BF4    SZDECR	0x74
  03E2    2BD6    JP	0x3D6
  03E3    0875    LD	A,0x75
  03E4    0008    RET
5:                {
6:                	unsigned char	quotient;
7:                	unsigned char	counter;
8:                
9:                	quotient = 0;
10:               	if(divisor != 0) {
11:               		counter = 1;
12:               		while((divisor & 0x80) == 0) {
13:               			divisor <<= 1;
14:               			counter++;
15:               		}
16:               		do {
17:               			quotient <<= 1;
18:               			if(divisor <= dividend) {
19:               				dividend -= divisor;
20:               				quotient |= 1;
21:               			}
22:               			divisor >>= 1;
23:               		} while(--counter != 0);
24:               	}
25:               	return quotient;
26:               }

583:              	else
584:              	{
585:              		ADCON0 = 0;						//如果转换没有完成，需初始化ADCON0,1
  01E2    1683    SETB	0x3,5
  01E3    0195    CLR	0x15
586:              		ADCON1 = 0;				
  01E4    0196    CLR	0x16
587:              		__delay_us(100);				//延时100us(编译器内置函数)
  01E5    3084    LDIA	0x84
  01E6    1283    CLRB	0x3,5
  01E7    00D1    LD	0x51,A
  01E8    0BD1    SZDECR	0x51
  01E9    29E8    JP	0x1E8
  01EA    29EB    JP	0x1EB
  01EB    0008    RET
588:              	}
589:              	
590:              }

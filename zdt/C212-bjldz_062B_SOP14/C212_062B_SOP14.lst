  0566    2D69    JP	0x569
  0567    0873    LD	A,0x73
  0568    0275    SUBA	0x75
  0569    1C03    SNZB	0x3,0
  056A    2D72    JP	0x572
  056B    0873    LD	A,0x73
  056C    02F5    SUBR	0x75
  056D    0874    LD	A,0x74
  056E    1C03    SNZB	0x3,0
  056F    03F6    DECR	0x76
  0570    02F6    SUBR	0x76
  0571    1003    CLRB	0x3,0
  0572    0CF4    RRCR	0x74
  0573    0CF3    RRCR	0x73
  0574    0BDB    SZDECR	0x5B
  0575    2D63    JP	0x563
  0576    0876    LD	A,0x76

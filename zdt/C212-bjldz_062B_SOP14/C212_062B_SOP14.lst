  0584    0188    CLR	0x8
851:              	WPDA = 0x02;					//RA1开下拉
  0585    3002    LDIA	0x2
  0586    0087    LD	0x7,A
852:              	WPUB = 0B00000100;
  0587    3004    LDIA	0x4
  0588    1283    CLRB	0x3,5
  0589    0088    LD	0x8,A
853:              
854:              	TRISA = 0x1F;				//配置IO状态，0为输出，1为输入
  058A    301F    LDIA	0x1F
  058B    1683    SETB	0x3,5
  058C    0085    LD	0x5,A
855:              	TRISB = 0B00000100;
  058D    3004    LDIA	0x4
  058E    1283    CLRB	0x3,5
  058F    0085    LD	0x5,A
856:              
857:              	PORTA = 0X00;
  0590    1683    SETB	0x3,5
  0591    0186    CLR	0x6
858:              	PORTB = 0X00;
  0592    1283    CLRB	0x3,5
  0593    0186    CLR	0x6
859:              
860:              //---------------------------------------
861:              //125us中断初始化
862:              	PR2 = 249;					//设定Timer初始值，定时周期是250*2/8M=62.5uS
  0594    30F9    LDIA	0xF9
  0595    0091    LD	0x11,A
863:              	TMR2IF = 0;
  0596    108D    CLRB	0xD,1

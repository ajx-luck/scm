870:              /***********************************************************
871:              中断服务函数
872:              函数名称：AD_Init()
873:              函数功能：AD初始化处理函数
874:              入口参数：
875:              出口参数：
876:              备    注：第一次打开AD允许位ADON，需延时20uS以上才能进入AD采样
877:              			如后继程序不关闭ADON，则不需要延时
878:              ***********************************************************/
879:              void AD_Init() 
880:              {
881:              	/*********** ADCON0 ****************************
882:              		Bit7~Bit6  ADCS<1:0>:  AD转换时钟选择位。
883:              			00=  F HSI /16
884:              			01=  F HSI /32
885:              			10=  F HSI /64
886:              			11=  F HSI /128
887:              		Bit5~Bit2  CHS<3:0>:  模拟通道选择位。与ADCON1寄存器CHS4组合CHS<3:0>
888:              			CHS<4:0>: 
889:              			00000=  AN0
890:              			00001=  AN1
891:              			00010=  AN2
892:              			00011=  AN3
893:              			00100=  AN4
894:              			00101=  AN5
895:              			00110=  保留
896:              			00111=  保留
897:              			01000=  AN8
898:              			… 
899:              			01101=  AN13
900:              			01110=  AN14
901:              			01111=  AN15
902:              			11111=  1.2V（固定参考电压）
903:              			其他=  保留
904:              		Bit1  GO/DONE: AD转换状态位。
905:              			1=  AD转换正在进行。将该位置1启动AD转换。当AD转换完成以后，该位由硬件自动清零。
906:              				当GO/DONE位从1变0或ADIF从0变1时，需至少等待两个TAD时间，才能再次启动AD转换。
907:              			0=  AD转换完成/或不在进行中。
908:              		Bit0  ADON:  ADC使能位。
909:              			1=  使能ADC；
910:              			0=  禁止ADC，不消耗工作电流。
911:              	*********************************************/
912:              	ADCON0 = 0X41;		//ADON开启，AD采样时间选为FSYS/16
  064B    3041    LDIA	0x41
  064C    1683    SETB	0x3,5
  064D    0095    LD	0x15,A
913:              	
914:              	/*********** ADCON1 ****************************
915:              		Bit7  ADFM:  AD转换结果格式选择位；
916:              			1=  右对齐；
917:              			0=  左对齐。
918:              		Bit6  CHS4:  通道选择位
919:              		Bit5~Bit3  未用 
920:              		Bit2  LDO_EN:  内部参考电压使能位。
921:              			1=  使能ADC内部LDO参考电压；
922:              				当选择内部LDO作参考电压时，ADC最大有效精度为8位。
923:              			0=  VDD作为ADC参考电压。
924:              		Bit1~Bit0  LDO_SEL<1:0>:  参考电压选择位
925:              			0X=  2.0V
926:              			10=  2.4V
927:              			11=  3.0V
928:              	*********************************************/
929:              	ADCON1 = 0;
  064E    0196    CLR	0x16
930:              	ANSEL0 = 0X1D;	
  064F    301D    LDIA	0x1D
  0650    0093    LD	0x13,A
  0651    0008    RET
931:              }
932:              
933:              
934:              void chrgPwmInit()
935:              {
936:              		PWMCON1 = 0B00000000;	//PWM选择A组，死区2禁止，死区1使能，死区时钟源为Fosc/4
937:              		
938:              		PWMTH = 0X00;			//周期选择为0FF，则周期为（255+1）*1/8M，周期的时钟分频在PWMCON0选择
939:              		PWMTL = 100;			//PWM 周期=[PWMT+1]*Tosc*(CLKDIV 分频值)
940:              		
941:              	
942:              		
943:              		PWMD01H = 0;			//配置PWM1,PWM2的占空比，该值不能超过周期，否者为100%输出
  062E    2635    CALL	0x635
944:              		PWMD0L = 1;			//互补模式，PWM1的占空比与PWM0互补，和设置值无关
  062F    3001    LDIA	0x1
  0630    0099    LD	0x19,A
945:              		PWM01DT = 0X00;			//死区设为2uS，计算为（3+1）*1/8M*4
  0631    019F    CLR	0x1F
946:              		
947:              		PWMCON0 = 0X01;			//打开PWM0 分频比为1
  0632    0095    LD	0x15,A
948:              		PWMCON2 =0X00;			//PWM4输出反向
  0633    019D    CLR	0x1D
  0634    0008    RET
949:              }
950:              
951:              void chrgPwmStop()
952:              {
953:              	PWMCON0 &= 0xFE;	//关闭PWM0
  065B    1015    CLRB	0x15,0
954:              	RB0 = 0;
  065C    1006    CLRB	0x6,0
  065D    0008    RET
955:              }
956:              
957:              void pwmInit()
958:              {
959:              		PWMCON1 = 0B00000000;	//PWM选择A组，死区2禁止，死区1使能，死区时钟源为Fosc/4
960:              		PWMTH = 0X00;			//周期选择为0FF，则周期为（255+1）*1/8M，周期的时钟分频在PWMCON0选择
961:              		PWMTL = 100;			//PWM 周期=[PWMT+1]*Tosc*(CLKDIV 分频值)
962:              		
963:              		
964:              		PWMD01H = 0;			//配置PWM1,PWM2的占空比，该值不能超过周期，否者为100%输出
  0643    2635    CALL	0x635
965:              		PWMD1L = 50;			//互补模式，PWM1的占空比与PWM0互补，和设置值无关
  0644    3032    LDIA	0x32
  0645    009A    LD	0x1A,A
966:              		PWM01DT = 0X00;			//死区设为2uS，计算为（3+1）*1/8M*4
  0646    019F    CLR	0x1F
967:              
968:              		PWMCON0 = 0X62;			//打开PWM1 分频比为8
  0647    3062    LDIA	0x62
  0648    0095    LD	0x15,A
969:              		PWMCON2 =0X00;			//PWM4输出反向
  0649    019D    CLR	0x1D
  064A    0008    RET
970:              }
971:              
972:              void pwmStop()
973:              {
974:              	PWMCON0 &= 0XFD;
  0658    1095    CLRB	0x15,1
975:              	RB1 = 0;
  0659    1086    CLRB	0x6,1
  065A    0008    RET
976:              }

979:              /***********************************************
980:              函数名称：Sleep_Mode
981:              函数功能：进入休眠模式
982:              入口参数：无
983:              出口参数：无
984:              备注：
985:              ************************************************/
986:              void Sleep_Mode()
987:              {
988:              	INTCON = 0;		
  04A5    018B    CLR	0xB
989:              	
990:              	OPTION_REG = 0;
  04A6    0181    CLR	0x1
991:              
992:              	TRISA = 0x1F; 		//关闭所有输出，RA0口做唤醒输入
  04A7    301F    LDIA	0x1F
  04A8    1683    SETB	0x3,5
  04A9    0085    LD	0x5,A
993:              	WPUA  = 0B00000000;			//RA0 开上拉电阻
  04AA    0188    CLR	0x8
994:              	PORTA = 0x00;
  04AB    0186    CLR	0x6
995:              	TRISB = 0B00000100;			//关闭所有输出，RB3口做唤醒输入
  04AC    3004    LDIA	0x4
  04AD    1283    CLRB	0x3,5
  04AE    0085    LD	0x5,A
996:              	PORTB = 0B00000000;
  04AF    0186    CLR	0x6
997:              	WPUB  = 0B00000100;			//RB2 开上拉电阻
  04B0    0088    LD	0x8,A
998:                 			
999:                 	ADCON0 = 0;					//关闭所有模块
  04B1    1683    SETB	0x3,5
  04B2    0195    CLR	0x15
1000:             	ADCON1 = 0;
  04B3    0196    CLR	0x16
1001:             	
1002:             	PWMCON0 = 0;
  04B4    1283    CLRB	0x3,5
  04B5    0195    CLR	0x15
1003:             		
1004:             	OSCCON = 0X70;				//配置振荡为8M,关闭WDT，需注意芯片工程选项里WDT必须选为DISABLE,否则无法软件关掉WDT
  04B6    3070    LDIA	0x70
  04B7    0094    LD	0x14,A
1005:             	
1006:             	IOCA = 0B00000010;			//允许RA1的IO电平变化中断
  04B8    3002    LDIA	0x2
  04B9    1683    SETB	0x3,5
  04BA    0089    LD	0x9,A
1007:             	IOCB = 0B00000100;			//允许RB3的IO口电平变化中断
  04BB    3004    LDIA	0x4
  04BC    1283    CLRB	0x3,5
  04BD    0089    LD	0x9,A
1008:             	
1009:             	RAIE = 1;					//允许PORTA的IO电平变化中断
  04BE    158E    SETB	0xE,3
1010:             	PEIE = 1;					//要用RORTA中断唤醒，则PEIE必须设为1
  04BF    170B    SETB	0xB,6
1011:             	RBIE = 1;					//允许PORTB电平变化中断
  04C0    158B    SETB	0xB,3
1012:             	GIE = 0;					//唤醒后执行SLEEP后程序;
  04C1    138B    CLRB	0xB,7
1013:             	
1014:             	PIE1 &= 0X08;				//关闭不需要的中断
  04C2    3008    LDIA	0x8
  04C3    058E    ANDR	0xE
1015:             	PIR1 = 0;					//必须清不需要的中断标志位
  04C4    018D    CLR	0xD
1016:             	INTCON &= 0XC8;				//必须清不需要的中断标志位
  04C5    30C8    LDIA	0xC8
  04C6    058B    ANDR	0xB
1017:             
1018:             	PORTA;						//读PORTA值并锁存,用电平变化中断必须执行这一步
  04C7    1683    SETB	0x3,5
  04C8    0806    LD	A,0x6
1019:             	RAIF = 0;					//清PORTA中断标志位
  04C9    1283    CLRB	0x3,5
  04CA    118D    CLRB	0xD,3
1020:             	PORTB;						//读PORTB值并锁存	
  04CB    0806    LD	A,0x6
1021:             	RBIF = 0;					//清PORTB中断标志位		
  04CC    100B    CLRB	0xB,0
  04CD    0064    CLRWDT

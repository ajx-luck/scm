835:              /**********************************************************
836:              函数名称：Init_System
837:              函数功能：系统初始化
838:              入口参数：无
839:              出口参数：无
840:              备    注：
841:              **********************************************************/
842:              void Init_System() 
  057B    0000    NOP
  057C    0064    CLRWDT
843:              {
844:              	asm("nop");
845:              	asm("clrwdt");
846:              	OPTION_REG = 0;					//预分频给TMR0 ，Timer0使用内部时钟Focs/4，预分频比为1:2
  057D    1283    CLRB	0x3,5
  057E    0181    CLR	0x1
  057F    0064    CLRWDT
847:              	asm("clrwdt");
848:              	OSCCON = 0X72;					//内部振荡器8M
  0580    3072    LDIA	0x72
  0581    1283    CLRB	0x3,5
  0582    0094    LD	0x14,A
849:              
850:              	WPUA = 0B00000000;				//配置上拉，1为使能上拉

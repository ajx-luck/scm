847:              /***********************************************************
848:              中断服务函数
849:              函数名称：AD_Init()
850:              函数功能：AD初始化处理函数
851:              入口参数：
852:              出口参数：
853:              备    注：第一次打开AD允许位ADON，需延时20uS以上才能进入AD采样
854:              			如后继程序不关闭ADON，则不需要延时
855:              ***********************************************************/
856:              void AD_Init() 
857:              {
858:              	/*********** ADCON0 ****************************
859:              		Bit7~Bit6  ADCS<1:0>:  AD转换时钟选择位。
860:              			00=  F HSI /16
861:              			01=  F HSI /32
862:              			10=  F HSI /64
863:              			11=  F HSI /128
864:              		Bit5~Bit2  CHS<3:0>:  模拟通道选择位。与ADCON1寄存器CHS4组合CHS<3:0>
865:              			CHS<4:0>: 
866:              			00000=  AN0
867:              			00001=  AN1
868:              			00010=  AN2
869:              			00011=  AN3
870:              			00100=  AN4
871:              			00101=  AN5
872:              			00110=  保留
873:              			00111=  保留
874:              			01000=  AN8
875:              			… 
876:              			01101=  AN13
877:              			01110=  AN14
878:              			01111=  AN15
879:              			11111=  1.2V（固定参考电压）
880:              			其他=  保留
881:              		Bit1  GO/DONE: AD转换状态位。
882:              			1=  AD转换正在进行。将该位置1启动AD转换。当AD转换完成以后，该位由硬件自动清零。
883:              				当GO/DONE位从1变0或ADIF从0变1时，需至少等待两个TAD时间，才能再次启动AD转换。
884:              			0=  AD转换完成/或不在进行中。
885:              		Bit0  ADON:  ADC使能位。
886:              			1=  使能ADC；
887:              			0=  禁止ADC，不消耗工作电流。
888:              	*********************************************/
889:              	ADCON0 = 0X41;		//ADON开启，AD采样时间选为FSYS/16
  05E3    3041    LDIA	0x41
  05E4    1683    SETB	0x3,5
  05E5    0095    LD	0x15,A
890:              	
891:              	/*********** ADCON1 ****************************
892:              		Bit7  ADFM:  AD转换结果格式选择位；
893:              			1=  右对齐；
894:              			0=  左对齐。
895:              		Bit6  CHS4:  通道选择位
896:              		Bit5~Bit3  未用 
897:              		Bit2  LDO_EN:  内部参考电压使能位。
898:              			1=  使能ADC内部LDO参考电压；
899:              				当选择内部LDO作参考电压时，ADC最大有效精度为8位。
900:              			0=  VDD作为ADC参考电压。
901:              		Bit1~Bit0  LDO_SEL<1:0>:  参考电压选择位
902:              			0X=  2.0V
903:              			10=  2.4V
904:              			11=  3.0V
905:              	*********************************************/
906:              	ADCON1 = 0;
  05E6    0196    CLR	0x16
907:              	ANSEL0 = 0X1D;	
  05E7    301D    LDIA	0x1D
  05E8    0093    LD	0x13,A
  05E9    0008    RET
908:              }
909:              
910:              
911:              void chrgPwmInit()
912:              {
913:              		PWMCON1 = 0B00000000;	//PWM选择A组，死区2禁止，死区1使能，死区时钟源为Fosc/4
914:              		
915:              		PWMTH = 0X00;			//周期选择为0FF，则周期为（255+1）*1/8M，周期的时钟分频在PWMCON0选择
916:              		PWMTL = 100;			//PWM 周期=[PWMT+1]*Tosc*(CLKDIV 分频值)
917:              		
918:              	
919:              		
920:              		PWMD01H = 0;			//配置PWM1,PWM2的占空比，该值不能超过周期，否者为100%输出
  05C6    25CD    CALL	0x5CD
921:              		PWMD0L = 1;			//互补模式，PWM1的占空比与PWM0互补，和设置值无关
  05C7    3001    LDIA	0x1
  05C8    0099    LD	0x19,A
922:              		PWM01DT = 0X00;			//死区设为2uS，计算为（3+1）*1/8M*4
  05C9    019F    CLR	0x1F
923:              		
924:              		PWMCON0 = 0X01;			//打开PWM0 分频比为1
  05CA    0095    LD	0x15,A
925:              		PWMCON2 =0X00;			//PWM4输出反向
  05CB    019D    CLR	0x1D
  05CC    0008    RET
926:              }
927:              
928:              void chrgPwmStop()
929:              {
930:              	PWMCON0 &= 0xFE;	//关闭PWM0
  05F3    1015    CLRB	0x15,0
931:              	RB0 = 0;
  05F4    1006    CLRB	0x6,0
  05F5    0008    RET
932:              }
933:              
934:              void pwmInit()
935:              {
936:              		PWMCON1 = 0B00000000;	//PWM选择A组，死区2禁止，死区1使能，死区时钟源为Fosc/4
937:              		PWMTH = 0X00;			//周期选择为0FF，则周期为（255+1）*1/8M，周期的时钟分频在PWMCON0选择
938:              		PWMTL = 100;			//PWM 周期=[PWMT+1]*Tosc*(CLKDIV 分频值)
939:              		
940:              		
941:              		PWMD01H = 0;			//配置PWM1,PWM2的占空比，该值不能超过周期，否者为100%输出
  05DB    25CD    CALL	0x5CD
942:              		PWMD1L = 50;			//互补模式，PWM1的占空比与PWM0互补，和设置值无关
  05DC    3032    LDIA	0x32
  05DD    009A    LD	0x1A,A
943:              		PWM01DT = 0X00;			//死区设为2uS，计算为（3+1）*1/8M*4
  05DE    019F    CLR	0x1F
944:              
945:              		PWMCON0 = 0X62;			//打开PWM1 分频比为8
  05DF    3062    LDIA	0x62
  05E0    0095    LD	0x15,A
946:              		PWMCON2 =0X00;			//PWM4输出反向
  05E1    019D    CLR	0x1D
  05E2    0008    RET
947:              }
948:              
949:              void pwmStop()
950:              {
951:              	PWMCON0 &= 0XFD;
  05F0    1095    CLRB	0x15,1
952:              	RB1 = 0;
  05F1    1086    CLRB	0x6,1
  05F2    0008    RET
953:              }

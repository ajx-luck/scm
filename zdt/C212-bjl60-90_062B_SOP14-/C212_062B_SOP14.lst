956:              /***********************************************
957:              函数名称：Sleep_Mode
958:              函数功能：进入休眠模式
959:              入口参数：无
960:              出口参数：无
961:              备注：
962:              ************************************************/
963:              void Sleep_Mode()
964:              {
965:              	INTCON = 0;		
  042A    018B    CLR	0xB
966:              	
967:              	OPTION_REG = 0;
  042B    0181    CLR	0x1
968:              
969:              	TRISA = 0x1F; 		//关闭所有输出，RA0口做唤醒输入
  042C    301F    LDIA	0x1F
  042D    1683    SETB	0x3,5
  042E    0085    LD	0x5,A
970:              	WPUA  = 0B00000000;			//RA0 开上拉电阻
  042F    0188    CLR	0x8
971:              	PORTA = 0x00;
  0430    0186    CLR	0x6
972:              	TRISB = 0B00000100;			//关闭所有输出，RB3口做唤醒输入
  0431    3004    LDIA	0x4
  0432    1283    CLRB	0x3,5
  0433    0085    LD	0x5,A
973:              	PORTB = 0B00000000;
  0434    0186    CLR	0x6
974:              	WPUB  = 0B00000100;			//RB2 开上拉电阻
  0435    0088    LD	0x8,A
975:                 			
976:                 	ADCON0 = 0;					//关闭所有模块
  0436    1683    SETB	0x3,5
  0437    0195    CLR	0x15
977:              	ADCON1 = 0;
  0438    0196    CLR	0x16
978:              	
979:              	PWMCON0 = 0;
  0439    1283    CLRB	0x3,5
  043A    0195    CLR	0x15
980:              		
981:              	OSCCON = 0X70;				//配置振荡为8M,关闭WDT，需注意芯片工程选项里WDT必须选为DISABLE,否则无法软件关掉WDT
  043B    3070    LDIA	0x70
  043C    0094    LD	0x14,A
982:              	
983:              	IOCA = 0B00000010;			//允许RA1的IO电平变化中断
  043D    3002    LDIA	0x2
  043E    1683    SETB	0x3,5
  043F    0089    LD	0x9,A
984:              	IOCB = 0B00000100;			//允许RB3的IO口电平变化中断
  0440    3004    LDIA	0x4
  0441    1283    CLRB	0x3,5
  0442    0089    LD	0x9,A
985:              	
986:              	RAIE = 1;					//允许PORTA的IO电平变化中断
  0443    158E    SETB	0xE,3
987:              	PEIE = 1;					//要用RORTA中断唤醒，则PEIE必须设为1
  0444    170B    SETB	0xB,6
988:              	RBIE = 1;					//允许PORTB电平变化中断
  0445    158B    SETB	0xB,3
989:              	GIE = 0;					//唤醒后执行SLEEP后程序;
  0446    138B    CLRB	0xB,7
990:              	
991:              	PIE1 &= 0X08;				//关闭不需要的中断
  0447    3008    LDIA	0x8
  0448    058E    ANDR	0xE
992:              	PIR1 = 0;					//必须清不需要的中断标志位
  0449    018D    CLR	0xD
993:              	INTCON &= 0XC8;				//必须清不需要的中断标志位
  044A    30C8    LDIA	0xC8
  044B    058B    ANDR	0xB
994:              
995:              	PORTA;						//读PORTA值并锁存,用电平变化中断必须执行这一步
  044C    1683    SETB	0x3,5
  044D    0806    LD	A,0x6
996:              	RAIF = 0;					//清PORTA中断标志位
  044E    1283    CLRB	0x3,5
  044F    118D    CLRB	0xD,3
997:              	PORTB;						//读PORTB值并锁存	
  0450    0806    LD	A,0x6
998:              	RBIF = 0;					//清PORTB中断标志位		
  0451    100B    CLRB	0xB,0
  0452    0064    CLRWDT
  0453    0063    STOP
  0454    0000    NOP
  0455    0064    CLRWDT
  0456    0000    NOP
  0457    0000    NOP
  0458    0000    NOP
  0459    0000    NOP
  045A    0000    NOP
999:              	asm("clrwdt");
1000:             
1001:             	asm("sleep");				//进入休眠模式
1002:             	
1003:             	asm("nop");
1004:             	asm("clrwdt");
1005:             	asm("nop");
1006:             	asm("nop");
1007:             	asm("nop");
1008:             	asm("nop");
1009:             	asm("nop");
1010:             	if(RAIF)  RAIF = 0;			//清中断标志
  045B    1283    CLRB	0x3,5
  045C    198D    SZB	0xD,3
  045D    118D    CLRB	0xD,3
1011:             	if(RBIF)  RBIF = 0;			//清中断标志
  045E    180B    SZB	0xB,0
  045F    100B    CLRB	0xB,0
1012:             	if(TMR2IF) TMR2IF = 0;
  0460    188D    SZB	0xD,1
  0461    108D    CLRB	0xD,1
1013:             	IOCA = 0B00000000;			//允许RA1的IO电平变化中断
  0462    1683    SETB	0x3,5
  0463    0189    CLR	0x9
1014:             	IOCB = 0B00000000;			//允许RB3的IO口电平变化中断
  0464    1283    CLRB	0x3,5
  0465    0189    CLR	0x9
1015:             	Init_System();
  0466    2532    CALL	0x532
1016:             	AD_Init();
  0467    2DE3    JP	0x5E3
1017:             }

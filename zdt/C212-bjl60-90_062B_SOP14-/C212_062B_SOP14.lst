1020:             
1021:             /**********************************************************
1022:             函数名称：AD_Sample
1023:             函数功能：AD检测
1024:             入口参数：adch - 检测通道
1025:             出口参数：无
1026:             备    注：采样通道需自行设置为输入口
1027:             	      采样10次,取中间八次的平均值为采样结果存于adresult中
1028:             
1029:             	      adch 为输入AD通道 0-15，31
1030:                          31  检测内部1.2V
1031:             	
1032:              		  adldo =5,开启内部LDO 2V 作为ADC 参考
1033:              		  adldo =6,开启内部LDO 2.4V 作为ADC 参考
1034:             		  adldo =7,开启内部LDO 3V 作为ADC 参考
1035:              		  adldo =0,VDD 作为ADC 参考
1036:              		  AD转换结果左对齐
1037:              		  ADC参考电压从VDD切换到LDO时需要延时100us以上，才能进行AD转换
1038:             **********************************************************/
1039:             unsigned char ADC_Sample(unsigned char adch, unsigned char adldo) 
  012D    1283    CLRB	0x3,5
  012E    00DC    LD	0x5C,A
1040:             {
1041:             	volatile unsigned long adsum = 0;
1042:             	volatile unsigned int admin = 0, admax = 0;
  012F    2208    CALL	0x208
1043:             	volatile unsigned int ad_temp = 0;
  0130    01E6    CLR	0x66
  0131    01E7    CLR	0x67
1044:             
1045:             	if ((!LDO_EN) && (adldo & 0x04) ) 
  0132    1683    SETB	0x3,5
  0133    1D16    SNZB	0x16,2
  0134    1D73    SNZB	0x73,2
  0135    293F    JP	0x13F
1046:             	{
1047:             								//如果AD参考从VDD换到内部LDO，需要延时100US以上
1048:             		ADCON1 = adldo;			//左对齐,AD值取12位
  0136    0873    LD	A,0x73
  0137    0096    LD	0x16,A
1049:             		__delay_us(100);		//IDE内置延时函数，延时100us
  0138    3084    LDIA	0x84
  0139    1283    CLRB	0x3,5
  013A    00D7    LD	0x57,A
  013B    0BD7    SZDECR	0x57
  013C    293B    JP	0x13B
  013D    293E    JP	0x13E
1050:             	} 
  013E    2941    JP	0x141

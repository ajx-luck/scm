812:              /**********************************************************
813:              函数名称：Init_System
814:              函数功能：系统初始化
815:              入口参数：无
816:              出口参数：无
817:              备    注：
818:              **********************************************************/
819:              void Init_System() 
  0532    0000    NOP
  0533    0064    CLRWDT
820:              {
821:              	asm("nop");
822:              	asm("clrwdt");
823:              	OPTION_REG = 0;					//预分频给TMR0 ，Timer0使用内部时钟Focs/4，预分频比为1:2
  0534    1283    CLRB	0x3,5
  0535    0181    CLR	0x1
  0536    0064    CLRWDT
824:              	asm("clrwdt");
825:              	OSCCON = 0X72;					//内部振荡器8M
  0537    3072    LDIA	0x72
  0538    1283    CLRB	0x3,5
  0539    0094    LD	0x14,A
826:              
827:              	WPUA = 0B00000000;				//配置上拉，1为使能上拉
  053A    1683    SETB	0x3,5
  053B    0188    CLR	0x8
828:              	WPDA = 0x02;					//RA1开下拉
  053C    3002    LDIA	0x2
  053D    0087    LD	0x7,A
829:              	WPUB = 0B00000100;
  053E    3004    LDIA	0x4
  053F    1283    CLRB	0x3,5
  0540    0088    LD	0x8,A
830:              
831:              	TRISA = 0x1F;				//配置IO状态，0为输出，1为输入
  0541    301F    LDIA	0x1F
  0542    1683    SETB	0x3,5
  0543    0085    LD	0x5,A
832:              	TRISB = 0B00000100;
  0544    3004    LDIA	0x4
  0545    1283    CLRB	0x3,5
  0546    0085    LD	0x5,A
833:              
834:              	PORTA = 0X00;
  0547    1683    SETB	0x3,5
  0548    0186    CLR	0x6
835:              	PORTB = 0X00;
  0549    1283    CLRB	0x3,5
  054A    0186    CLR	0x6
836:              
837:              //---------------------------------------
838:              //125us中断初始化
839:              	PR2 = 249;					//设定Timer初始值，定时周期是250*2/8M=62.5uS
  054B    30F9    LDIA	0xF9
  054C    0091    LD	0x11,A
840:              	TMR2IF = 0;
  054D    108D    CLRB	0xD,1
841:              	TMR2IE = 1;					//使能Timer2溢出中断
  054E    148E    SETB	0xE,1
842:              

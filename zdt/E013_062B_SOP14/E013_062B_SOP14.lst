410:              /**********************************************************
411:              函数名称：Init_System
412:              函数功能：系统初始化
413:              入口参数：无
414:              出口参数：无
415:              备    注：
416:              **********************************************************/
417:              void Init_System() 
  028C    0000    NOP
  028D    0064    CLRWDT
418:              {
419:              	asm("nop");
420:              	asm("clrwdt");
421:              	OPTION_REG = 0;					//预分频给TMR0 ，Timer0使用内部时钟Focs/4，预分频比为1:2
  028E    1283    CLRB	0x3,5
  028F    0181    CLR	0x1
  0290    0064    CLRWDT
422:              	asm("clrwdt");
423:              	OSCCON = 0X72;					//内部振荡器8M
  0291    3072    LDIA	0x72
  0292    1283    CLRB	0x3,5
  0293    0094    LD	0x14,A
424:              
425:              	WPUA = 0B00000000;				//配置上拉，1为使能上拉
  0294    1683    SETB	0x3,5
  0295    0188    CLR	0x8
426:              	WPDA = 0x00;					//RA1开下拉
  0296    0187    CLR	0x7
427:              	WPUB = 0x01;
  0297    3001    LDIA	0x1
  0298    1283    CLRB	0x3,5
  0299    0088    LD	0x8,A
428:              
429:              	TRISA = 0x20;				//配置IO状态，0为输出，1为输入
  029A    3020    LDIA	0x20
  029B    1683    SETB	0x3,5
430:              	TRISB = 0x01;
431:              
432:              	PORTA = 0X00;
433:              	PORTB = 0X00;
  029C    21DB    CALL	0x1DB
434:              
435:              //---------------------------------------
436:              //125us中断初始化
437:              	PR2 = 249;					//设定Timer初始值，定时周期是250*2/8M=62.5uS
  029D    30F9    LDIA	0xF9
  029E    0091    LD	0x11,A
438:              	TMR2IF = 0;
  029F    108D    CLRB	0xD,1
439:              	TMR2IE = 1;					//使能Timer2溢出中断
  02A0    148E    SETB	0xE,1
440:              
441:              	T2CON = 0B00000100;			//开启Timer2,设置TMR2的分频比为1:1
  02A1    3004    LDIA	0x4
  02A2    0093    LD	0x13,A
442:              	INTCON = 0XC0;				//开启总中断
  02A3    30C0    LDIA	0xC0
  02A4    008B    LD	0xB,A
  02A5    0008    RET
443:              }
444:              
445:              /***********************************************************
446:              中断服务函数
447:              函数名称：AD_Init()
448:              函数功能：AD初始化处理函数
449:              入口参数：
450:              出口参数：
451:              备    注：第一次打开AD允许位ADON，需延时20uS以上才能进入AD采样
452:              			如后继程序不关闭ADON，则不需要延时
453:              ***********************************************************/
454:              void AD_Init() 
455:              {
456:              	/*********** ADCON0 ****************************
457:              		Bit7~Bit6  ADCS<1:0>:  AD转换时钟选择位。
458:              			00=  F HSI /16
459:              			01=  F HSI /32
460:              			10=  F HSI /64
461:              			11=  F HSI /128
462:              		Bit5~Bit2  CHS<3:0>:  模拟通道选择位。与ADCON1寄存器CHS4组合CHS<3:0>
463:              			CHS<4:0>: 
464:              			00000=  AN0
465:              			00001=  AN1
466:              			00010=  AN2
467:              			00011=  AN3
468:              			00100=  AN4
469:              			00101=  AN5
470:              			00110=  保留
471:              			00111=  保留
472:              			01000=  AN8
473:              			… 
474:              			01101=  AN13
475:              			01110=  AN14
476:              			01111=  AN15
477:              			11111=  1.2V（固定参考电压）
478:              			其他=  保留
479:              		Bit1  GO/DONE: AD转换状态位。
480:              			1=  AD转换正在进行。将该位置1启动AD转换。当AD转换完成以后，该位由硬件自动清零。
481:              				当GO/DONE位从1变0或ADIF从0变1时，需至少等待两个TAD时间，才能再次启动AD转换。
482:              			0=  AD转换完成/或不在进行中。
483:              		Bit0  ADON:  ADC使能位。
484:              			1=  使能ADC；
485:              			0=  禁止ADC，不消耗工作电流。
486:              	*********************************************/
487:              	ADCON0 = 0X41;		//ADON开启，AD采样时间选为FSYS/16
  02EF    3041    LDIA	0x41
  02F0    1683    SETB	0x3,5
  02F1    0095    LD	0x15,A
488:              	
489:              	/*********** ADCON1 ****************************
490:              		Bit7  ADFM:  AD转换结果格式选择位；
491:              			1=  右对齐；
492:              			0=  左对齐。
493:              		Bit6  CHS4:  通道选择位
494:              		Bit5~Bit3  未用 
495:              		Bit2  LDO_EN:  内部参考电压使能位。
496:              			1=  使能ADC内部LDO参考电压；
497:              				当选择内部LDO作参考电压时，ADC最大有效精度为8位。
498:              			0=  VDD作为ADC参考电压。
499:              		Bit1~Bit0  LDO_SEL<1:0>:  参考电压选择位
500:              			0X=  2.0V
501:              			10=  2.4V
502:              			11=  3.0V
503:              	*********************************************/
504:              	ADCON1 = 0;
  02F2    0196    CLR	0x16
505:              	ANSEL0 = 0X20;
  02F3    3020    LDIA	0x20
  02F4    0093    LD	0x13,A
506:              	ANSEL1 = 0x00;	
  02F5    0194    CLR	0x14
  02F6    0008    RET
507:              }
508:              
509:              
510:              /***********************************************
511:              函数名称：Sleep_Mode
512:              函数功能：进入休眠模式
513:              入口参数：无
514:              出口参数：无
515:              备注：
516:              ************************************************/
517:              void Sleep_Mode()
518:              {
519:              	INTCON = 0;		
  01A3    018B    CLR	0xB
520:              	
521:              	OPTION_REG = 0;
  01A4    0181    CLR	0x1
522:              
523:              	WPUA  = 0B00000000;			//RA0 开上拉电阻
  01A5    1683    SETB	0x3,5
  01A6    0188    CLR	0x8
524:              	TRISA = 0x20;				//配置IO状态，0为输出，1为输入
  01A7    3020    LDIA	0x20
525:              	TRISB = 0x01;
526:              
527:              	PORTA = 0X00;
528:              	PORTB = 0X00;
  01A8    21DB    CALL	0x1DB
529:              	WPUB  = 0x01;			//RB2 开上拉电阻
  01A9    0088    LD	0x8,A
530:                 			
531:                 	ADCON0 = 0;					//关闭所有模块
  01AA    1683    SETB	0x3,5
  01AB    0195    CLR	0x15
532:              	ADCON1 = 0;
  01AC    0196    CLR	0x16
533:              	
534:              	PWMCON0 = 0;
  01AD    1283    CLRB	0x3,5
  01AE    0195    CLR	0x15
535:              		
536:              	OSCCON = 0X70;				//配置振荡为8M,关闭WDT，需注意芯片工程选项里WDT必须选为DISABLE,否则无法软件关掉WDT
  01AF    3070    LDIA	0x70
  01B0    0094    LD	0x14,A
537:              	
538:              	IOCA = 0x00;			//允许RA1的IO电平变化中断
  01B1    1683    SETB	0x3,5
  01B2    0189    CLR	0x9
539:              	IOCB = 0x01;			//允许RB3的IO口电平变化中断
  01B3    3001    LDIA	0x1
  01B4    1283    CLRB	0x3,5
  01B5    0089    LD	0x9,A
540:              	
541:              	RAIE = 1;					//允许PORTA的IO电平变化中断
  01B6    158E    SETB	0xE,3
542:              	PEIE = 1;					//要用RORTA中断唤醒，则PEIE必须设为1
  01B7    170B    SETB	0xB,6
543:              	RBIE = 1;					//允许PORTB电平变化中断
  01B8    158B    SETB	0xB,3
544:              	GIE = 0;					//唤醒后执行SLEEP后程序;
  01B9    138B    CLRB	0xB,7
545:              	
546:              	PIE1 &= 0X08;				//关闭不需要的中断
  01BA    3008    LDIA	0x8
  01BB    058E    ANDR	0xE
547:              	PIR1 = 0;					//必须清不需要的中断标志位
  01BC    018D    CLR	0xD
548:              	INTCON &= 0XC8;				//必须清不需要的中断标志位
  01BD    30C8    LDIA	0xC8
  01BE    058B    ANDR	0xB
549:              
550:              	PORTA;						//读PORTA值并锁存,用电平变化中断必须执行这一步
  01BF    1683    SETB	0x3,5
  01C0    0806    LD	A,0x6
551:              	RAIF = 0;					//清PORTA中断标志位
  01C1    1283    CLRB	0x3,5
  01C2    118D    CLRB	0xD,3
552:              	PORTB;						//读PORTB值并锁存	
  01C3    0806    LD	A,0x6
553:              	RBIF = 0;					//清PORTB中断标志位		
  01C4    100B    CLRB	0xB,0
  01C5    0064    CLRWDT
  01C6    0063    STOP
  01C7    0000    NOP
  01C8    0064    CLRWDT
  01C9    0000    NOP
  01CA    0000    NOP
  01CB    0000    NOP
  01CC    0000    NOP
  01CD    0000    NOP
554:              	asm("clrwdt");
555:              
556:              	asm("sleep");				//进入休眠模式
557:              	
558:              	asm("nop");
559:              	asm("clrwdt");
560:              	asm("nop");
561:              	asm("nop");
562:              	asm("nop");
563:              	asm("nop");
564:              	asm("nop");
565:              	if(RAIF)  RAIF = 0;			//清中断标志
  01CE    1283    CLRB	0x3,5
  01CF    198D    SZB	0xD,3
  01D0    118D    CLRB	0xD,3
566:              	if(RBIF)  RBIF = 0;			//清中断标志
  01D1    180B    SZB	0xB,0
  01D2    100B    CLRB	0xB,0
567:              	if(TMR2IF) TMR2IF = 0;
  01D3    188D    SZB	0xD,1
  01D4    108D    CLRB	0xD,1
568:              	IOCA = 0B00000000;			//允许RA1的IO电平变化中断
  01D5    1683    SETB	0x3,5
  01D6    0189    CLR	0x9
569:              	IOCB = 0B00000000;			//允许RB3的IO口电平变化中断
  01D7    1283    CLRB	0x3,5
  01D8    0189    CLR	0x9
570:              	Init_System();
  01D9    228C    CALL	0x28C
571:              	AD_Init();
  01DA    2AEF    JP	0x2EF
572:              }

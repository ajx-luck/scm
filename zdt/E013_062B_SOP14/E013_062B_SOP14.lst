576:              /**********************************************************
577:              函数名称：AD_Sample
578:              函数功能：AD检测
579:              入口参数：adch - 检测通道
580:              出口参数：无
581:              备    注：采样通道需自行设置为输入口
582:              	      采样10次,取中间八次的平均值为采样结果存于adresult中
583:              
584:              	      adch 为输入AD通道 0-15，31
585:                           31  检测内部1.2V
586:              	
587:               		  adldo =5,开启内部LDO 2V 作为ADC 参考
588:               		  adldo =6,开启内部LDO 2.4V 作为ADC 参考
589:              		  adldo =7,开启内部LDO 3V 作为ADC 参考
590:               		  adldo =0,VDD 作为ADC 参考
591:               		  AD转换结果左对齐
592:               		  ADC参考电压从VDD切换到LDO时需要延时100us以上，才能进行AD转换
593:              **********************************************************/
594:              unsigned char ADC_Sample(unsigned char adch, unsigned char adldo) 
  0018    00A5    LD	0x25,A
595:              {
596:              	volatile unsigned long adsum = 0;
597:              	volatile unsigned int admin = 0, admax = 0;
  0019    20F2    CALL	0xF2
598:              	volatile unsigned int ad_temp = 0;
  001A    01AF    CLR	0x2F
  001B    01B0    CLR	0x30
599:              
600:              	if ((!LDO_EN) && (adldo & 0x04) ) 
  001C    1683    SETB	0x3,5
  001D    1D16    SNZB	0x16,2
  001E    1D73    SNZB	0x73,2
  001F    2829    JP	0x29
601:              	{
602:              								//如果AD参考从VDD换到内部LDO，需要延时100US以上
603:              		ADCON1 = adldo;			//左对齐,AD值取12位
  0020    0873    LD	A,0x73
  0021    0096    LD	0x16,A
604:              		__delay_us(100);		//IDE内置延时函数，延时100us
  0022    3084    LDIA	0x84
  0023    1283    CLRB	0x3,5
  0024    00A0    LD	0x20,A
  0025    0BA0    SZDECR	0x20
  0026    2825    JP	0x25
  0027    2828    JP	0x28
605:              	} 
  0028    282B    JP	0x2B
606:              	else
607:              		ADCON1 = adldo;			//如果ADCON1.7(ADFM)=1为右对齐，,AD值取10位
  0029    0873    LD	A,0x73
  002A    0096    LD	0x16,A
608:              
609:              	if(adch & 0x10) 
  002B    1283    CLRB	0x3,5
  002C    1E25    SNZB	0x25,4
  002D    2833    JP	0x33
610:              	{
611:              		CHS4 = 1;
  002E    1683    SETB	0x3,5
  002F    1716    SETB	0x16,6
612:              		adch &= 0x0f;
  0030    300F    LDIA	0xF
  0031    1283    CLRB	0x3,5
  0032    05A5    ANDR	0x25
613:              	}
614:              	unsigned char i = 0;
615:              	for (i = 0; i < 10; i++) 
  0033    01A6    CLR	0x26
616:              	{
617:              		ADCON0 = (unsigned char)(0X41 | (adch << 2));	//16分频，如果主频为16M，则必须选16分频或以上
  0034    0825    LD	A,0x25
  0035    00A0    LD	0x20,A
  0036    3001    LDIA	0x1
  0037    1003    CLRB	0x3,0
  0038    0DA0    RLCR	0x20
  0039    3EFF    ADDIA	0xFF
  003A    1003    CLRB	0x3,0
  003B    1D03    SNZB	0x3,2
  003C    2838    JP	0x38
  003D    0D20    RLCA	0x20
  003E    3841    ORIA	0x41
  003F    1683    SETB	0x3,5
  0040    0095    LD	0x15,A
  0041    0000    NOP
  0042    0000    NOP
  0043    0000    NOP
  0044    0000    NOP
618:              		asm("nop");
619:              		asm("nop");
620:              		asm("nop");
621:              		asm("nop");				//选择通道后需延时1uS以上
622:              		GODONE = 1;				//开始转换
  0045    1683    SETB	0x3,5
  0046    1495    SETB	0x15,1
623:              
624:              		unsigned char j = 0;
  0047    1283    CLRB	0x3,5
  0048    01A4    CLR	0x24
625:              		while (GODONE) 
  0049    1683    SETB	0x3,5
  004A    1C95    SNZB	0x15,1
  004B    2854    JP	0x54
626:              		{
627:              			__delay_us(2);		//延时2us(编译器内置函数)

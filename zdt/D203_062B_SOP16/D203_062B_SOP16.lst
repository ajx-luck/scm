  02F4    0008    RET
499:              }
500:              
501:              /***********************************************************
502:              中断服务函数
503:              函数名称：AD_Init()
504:              函数功能：AD初始化处理函数
505:              入口参数：
506:              出口参数：
507:              备    注：第一次打开AD允许位ADON，需延时20uS以上才能进入AD采样
508:              			如后继程序不关闭ADON，则不需要延时
509:              ***********************************************************/
510:              void AD_Init() 
511:              {
512:              	/*********** ADCON0 ****************************
513:              		Bit7~Bit6  ADCS<1:0>:  AD转换时钟选择位。
514:              			00=  F HSI /16
515:              			01=  F HSI /32
516:              			10=  F HSI /64
517:              			11=  F HSI /128
518:              		Bit5~Bit2  CHS<3:0>:  模拟通道选择位。与ADCON1寄存器CHS4组合CHS<3:0>
519:              			CHS<4:0>: 
520:              			00000=  AN0
521:              			00001=  AN1
522:              			00010=  AN2
523:              			00011=  AN3
524:              			00100=  AN4
525:              			00101=  AN5
526:              			00110=  保留
527:              			00111=  保留
528:              			01000=  AN8
529:              			… 
530:              			01101=  AN13
531:              			01110=  AN14
532:              			01111=  AN15
533:              			11111=  1.2V（固定参考电压）
534:              			其他=  保留
535:              		Bit1  GO/DONE: AD转换状态位。
536:              			1=  AD转换正在进行。将该位置1启动AD转换。当AD转换完成以后，该位由硬件自动清零。
537:              				当GO/DONE位从1变0或ADIF从0变1时，需至少等待两个TAD时间，才能再次启动AD转换。
538:              			0=  AD转换完成/或不在进行中。
539:              		Bit0  ADON:  ADC使能位。
540:              			1=  使能ADC；
541:              			0=  禁止ADC，不消耗工作电流。
542:              	*********************************************/
543:              	ADCON0 = 0X41;		//ADON开启，AD采样时间选为FSYS/16
  0380    3041    LDIA	0x41
  0381    1683    SETB	0x3,5
  0382    0095    LD	0x15,A
544:              	
545:              	/*********** ADCON1 ****************************
546:              		Bit7  ADFM:  AD转换结果格式选择位；
547:              			1=  右对齐；
548:              			0=  左对齐。
549:              		Bit6  CHS4:  通道选择位
550:              		Bit5~Bit3  未用 
551:              		Bit2  LDO_EN:  内部参考电压使能位。
552:              			1=  使能ADC内部LDO参考电压；
553:              				当选择内部LDO作参考电压时，ADC最大有效精度为8位。
554:              			0=  VDD作为ADC参考电压。
555:              		Bit1~Bit0  LDO_SEL<1:0>:  参考电压选择位
556:              			0X=  2.0V
557:              			10=  2.4V
558:              			11=  3.0V
559:              	*********************************************/
560:              	ADCON1 = 0;
  0383    0196    CLR	0x16
561:              	ANSEL0 = 0X07;	
  0384    3007    LDIA	0x7
  0385    0093    LD	0x13,A
  0386    0008    RET
562:              }
563:              
564:              
565:              void pwmInit()
566:              {
567:              		PWMCON1 = 0B00000000;	//PWM选择D组，死区2禁止，死区1使能，死区时钟源为Fosc/4
  036A    0196    CLR	0x16
568:              		PWMTH = 0X00;			//周期选择为0FF，则周期为（255+1）*1/8M，周期的时钟分频在PWMCON0选择
  036B    0198    CLR	0x18
569:              		PWMTL = 100;			//PWM 周期=[PWMT+1]*Tosc*(CLKDIV 分频值)
  036C    3064    LDIA	0x64
  036D    0097    LD	0x17,A
570:              		
571:              		
572:              		PWMD23H = 0;			//配置PWM1,PWM2的占空比，该值不能超过周期，否者为100%输出
  036E    1683    SETB	0x3,5
  036F    019E    CLR	0x1E
573:              		PWMD3L = 45;			//互补模式，PWM1的占空比与PWM0互补，和设置值无关
  0370    302D    LDIA	0x2D
  0371    009C    LD	0x1C,A

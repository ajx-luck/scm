466:              /**********************************************************
467:              函数名称：Init_System
468:              函数功能：系统初始化
469:              入口参数：无
470:              出口参数：无
471:              备    注：
472:              **********************************************************/
473:              void Init_System() 
  02D2    0000    NOP
  02D3    0064    CLRWDT
474:              {
475:              	asm("nop");
476:              	asm("clrwdt");
477:              	OPTION_REG = 0;					//预分频给TMR0 ，Timer0使用内部时钟Focs/4，预分频比为1:2
  02D4    1283    CLRB	0x3,5
  02D5    0181    CLR	0x1
  02D6    0064    CLRWDT
478:              	asm("clrwdt");
479:              	OSCCON = 0X72;					//内部振荡器8M
  02D7    3072    LDIA	0x72
  02D8    1283    CLRB	0x3,5
  02D9    0094    LD	0x14,A
480:              
481:              	WPUA = 0B00000000;				//配置上拉，1为使能上拉
  02DA    1683    SETB	0x3,5
  02DB    0188    CLR	0x8
482:              	WPDA = 0x00;					//RA1开下拉
  02DC    0187    CLR	0x7
483:              	WPUB = 0x20;
  02DD    3020    LDIA	0x20
  02DE    1283    CLRB	0x3,5
  02DF    0088    LD	0x8,A
484:              
485:              	TRISA = 0x07;				//配置IO状态，0为输出，1为输入
  02E0    3007    LDIA	0x7
  02E1    1683    SETB	0x3,5
  02E2    0085    LD	0x5,A
486:              	TRISB = 0x24;
  02E3    3024    LDIA	0x24
  02E4    1283    CLRB	0x3,5
  02E5    0085    LD	0x5,A
487:              
488:              	PORTA = 0X08;
  02E6    3008    LDIA	0x8
  02E7    1683    SETB	0x3,5
  02E8    0086    LD	0x6,A
489:              	PORTB = 0X03;
  02E9    3003    LDIA	0x3
  02EA    1283    CLRB	0x3,5
  02EB    0086    LD	0x6,A
490:              
491:              //---------------------------------------
492:              //125us中断初始化

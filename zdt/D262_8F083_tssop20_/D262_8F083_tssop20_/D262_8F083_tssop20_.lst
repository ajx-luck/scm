156:               /*-------------------------------------------------
157:               *	函数名：	DelayMs
158:               *	功能： 	 	短延时函数
159:               *	输入参数：Time延时时间长度 延时时长Time ms
160:               *	返回参数： 无
161:               --------------------------------------------------*/
162:               void DelayMs(uchar Time)
163:               {
164:                   uchar a,b;
165:                   for(a=0;a<Time;a++)
166:                   {
167:                       for(b=0;b<5;b++)
168:                       {
169:                           DelayUs(197);
170:                       }
171:                   }
172:               }
173:               /*-------------------------------------------------
174:               *	函数名：	DelayS
175:               *	功能： 	 	短延时函数
176:               *	输入参数：Time延时时间长度 延时时长Time S
177:               *	返回参数： 无
178:               --------------------------------------------------*/
179:               void DelayS(uchar Time)
180:               {
181:                   uchar a,b;
182:                   for(a=0;a<Time;a++)
183:                   {
184:                       for(b=0;b<10;b++)
185:                       {
186:                           DelayMs(100);
187:                       }
188:                   }
189:               }

181:              void Refurbish_Sfr() 
182:              {
183:              	//刷新中断相关控制寄存器
184:              	PIE1 = 2;
185:              	PR2 = 100;
186:              	INTCON = 0XC0;
187:              	if (5 != T2CON)
188:              		T2CON = 5;
189:              }

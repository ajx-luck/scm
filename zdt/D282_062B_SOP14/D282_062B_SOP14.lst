997:              /**********************************************************
998:              函数名称：AD_Sample
999:              函数功能：AD检测
1000:             入口参数：adch - 检测通道
1001:             出口参数：无
1002:             备    注：采样通道需自行设置为输入口
1003:             	      采样10次,取中间八次的平均值为采样结果存于adresult中
1004:             
1005:             	      adch 为输入AD通道 0-15，31
1006:                          31  检测内部1.2V
1007:             	
1008:              		  adldo =5,开启内部LDO 2V 作为ADC 参考
1009:              		  adldo =6,开启内部LDO 2.4V 作为ADC 参考
1010:             		  adldo =7,开启内部LDO 3V 作为ADC 参考
1011:              		  adldo =0,VDD 作为ADC 参考
1012:              		  AD转换结果左对齐
1013:              		  ADC参考电压从VDD切换到LDO时需要延时100us以上，才能进行AD转换
1014:             **********************************************************/
1015:             unsigned char ADC_Sample(unsigned char adch, unsigned char adldo) 
  0124    1283    CLRB	0x3,5
  0125    00DB    LD	0x5B,A
1016:             {
1017:             	volatile unsigned long adsum = 0;
1018:             	volatile unsigned int admin = 0, admax = 0;
  0126    21FF    CALL	0x1FF
1019:             	volatile unsigned int ad_temp = 0;
  0127    01E5    CLR	0x65
  0128    01E6    CLR	0x66
1020:             
1021:             	if ((!LDO_EN) && (adldo & 0x04) ) 
  0129    1683    SETB	0x3,5
  012A    1D16    SNZB	0x16,2
  012B    1D73    SNZB	0x73,2
  012C    2936    JP	0x136
1022:             	{
1023:             								//如果AD参考从VDD换到内部LDO，需要延时100US以上
1024:             		ADCON1 = adldo;			//左对齐,AD值取12位
  012D    0873    LD	A,0x73
  012E    0096    LD	0x16,A
1025:             		__delay_us(100);		//IDE内置延时函数，延时100us
  012F    3084    LDIA	0x84
  0130    1283    CLRB	0x3,5
  0131    00D6    LD	0x56,A
  0132    0BD6    SZDECR	0x56
  0133    2932    JP	0x132
  0134    2935    JP	0x135
1026:             	} 
  0135    2938    JP	0x138
1027:             	else
1028:             		ADCON1 = adldo;			//如果ADCON1.7(ADFM)=1为右对齐，,AD值取10位
  0136    0873    LD	A,0x73
  0137    0096    LD	0x16,A
1029:             
1030:             	if(adch & 0x10) 
  0138    1283    CLRB	0x3,5
  0139    1E5B    SNZB	0x5B,4
  013A    2940    JP	0x140
1031:             	{
1032:             		CHS4 = 1;
  013B    1683    SETB	0x3,5
  013C    1716    SETB	0x16,6
1033:             		adch &= 0x0f;
  013D    300F    LDIA	0xF
  013E    1283    CLRB	0x3,5
  013F    05DB    ANDR	0x5B
1034:             	}
1035:             	unsigned char i = 0;
1036:             	for (i = 0; i < 10; i++) 
  0140    01DC    CLR	0x5C
1037:             	{
1038:             		ADCON0 = (unsigned char)(0X41 | (adch << 2));	//16分频，如果主频为16M，则必须选16分频或以上
  0141    085B    LD	A,0x5B
  0142    00D6    LD	0x56,A
  0143    3001    LDIA	0x1
  0144    1003    CLRB	0x3,0
  0145    0DD6    RLCR	0x56
  0146    3EFF    ADDIA	0xFF
  0147    1003    CLRB	0x3,0
  0148    1D03    SNZB	0x3,2
  0149    2945    JP	0x145
  014A    0D56    RLCA	0x56
  014B    3841    ORIA	0x41
  014C    1683    SETB	0x3,5
  014D    0095    LD	0x15,A
  014E    0000    NOP
  014F    0000    NOP
  0150    0000    NOP
  0151    0000    NOP
1039:             		asm("nop");
1040:             		asm("nop");
1041:             		asm("nop");
1042:             		asm("nop");				//选择通道后需延时1uS以上
1043:             		GODONE = 1;				//开始转换
  0152    1683    SETB	0x3,5
  0153    1495    SETB	0x15,1
1044:             
1045:             		unsigned char j = 0;
  0154    1283    CLRB	0x3,5
  0155    01DA    CLR	0x5A
1046:             		while (GODONE) 
  0156    1683    SETB	0x3,5
  0157    1C95    SNZB	0x15,1
  0158    2961    JP	0x161
1047:             		{
1048:             			__delay_us(2);		//延时2us(编译器内置函数)
  0159    295A    JP	0x15A
  015A    295B    JP	0x15B
  015B    295C    JP	0x15C
  015C    295D    JP	0x15D
1049:             
1050:             			if (0 == (--j))		//延时0.5ms仍没有AD转换结束，跳出程序
  015D    1283    CLRB	0x3,5
  015E    0BDA    SZDECR	0x5A
  015F    2956    JP	0x156
1051:             			return 0;
  0160    3400    RET	0x0

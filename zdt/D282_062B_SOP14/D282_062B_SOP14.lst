  035D    01CE    CLR	0x4E
775:              	    	}
776:              	    }
777:              	}
  035E    0008    RET
778:              	else
779:              	{
780:              		ADCON0 = 0;						//如果转换没有完成，需初始化ADCON0,1
  035F    1683    SETB	0x3,5
  0360    0195    CLR	0x15
781:              		ADCON1 = 0;				
  0361    0196    CLR	0x16
782:              		__delay_us(100);				//延时100us(编译器内置函数)
  0362    3085    LDIA	0x85
  0363    00F4    LD	0x74,A
  0364    0BF4    SZDECR	0x74
  0365    2B64    JP	0x364
  0366    0008    RET
783:              	}
784:              }

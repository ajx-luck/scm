799:              /**********************************************************
800:              函数名称：Init_System
801:              函数功能：系统初始化
802:              入口参数：无
803:              出口参数：无
804:              备    注：
805:              **********************************************************/
806:              void Init_System() 
  0521    0000    NOP
  0522    0064    CLRWDT
807:              {
808:              	asm("nop");
809:              	asm("clrwdt");
810:              	OPTION_REG = 0;					//预分频给TMR0 ，Timer0使用内部时钟Focs/4，预分频比为1:2
  0523    1283    CLRB	0x3,5
  0524    0181    CLR	0x1
  0525    0064    CLRWDT
811:              	asm("clrwdt");
812:              	OSCCON = 0X72;					//内部振荡器8M
  0526    3072    LDIA	0x72
  0527    1283    CLRB	0x3,5
  0528    0094    LD	0x14,A
813:              
814:              	WPUA = 0B00000000;				//配置上拉，1为使能上拉
  0529    1683    SETB	0x3,5
  052A    0188    CLR	0x8
815:              	WPDA = 0x02;					//RA1开下拉
  052B    3002    LDIA	0x2
  052C    0087    LD	0x7,A
816:              	WPUB = 0B00000100;
  052D    3004    LDIA	0x4
  052E    1283    CLRB	0x3,5
  052F    0088    LD	0x8,A
817:              
818:              	TRISA = 0x1F;				//配置IO状态，0为输出，1为输入
  0530    301F    LDIA	0x1F
  0531    1683    SETB	0x3,5
  0532    0085    LD	0x5,A
819:              	TRISB = 0B00000100;
  0533    3004    LDIA	0x4
  0534    1283    CLRB	0x3,5
  0535    0085    LD	0x5,A
820:              
821:              	PORTA = 0X00;
  0536    1683    SETB	0x3,5
  0537    0186    CLR	0x6
822:              	PORTB = 0X00;
  0538    1283    CLRB	0x3,5
  0539    0186    CLR	0x6
823:              
824:              //---------------------------------------
825:              //125us中断初始化
826:              	PR2 = 249;					//设定Timer初始值，定时周期是250*2/8M=62.5uS
  053A    30F9    LDIA	0xF9
  053B    0091    LD	0x11,A
827:              	TMR2IF = 0;
  053C    108D    CLRB	0xD,1
828:              	TMR2IE = 1;					//使能Timer2溢出中断
  053D    148E    SETB	0xE,1
829:              
830:              	T2CON = 0B00000100;			//开启Timer2,设置TMR2的分频比为1:1
  053E    3004    LDIA	0x4
  053F    0093    LD	0x13,A
831:              	INTCON = 0XC0;				//开启总中断
  0540    30C0    LDIA	0xC0
  0541    008B    LD	0xB,A
  0542    0008    RET
832:              }
833:              
834:              /***********************************************************
835:              中断服务函数
836:              函数名称：AD_Init()
837:              函数功能：AD初始化处理函数
838:              入口参数：
839:              出口参数：
840:              备    注：第一次打开AD允许位ADON，需延时20uS以上才能进入AD采样
841:              			如后继程序不关闭ADON，则不需要延时
842:              ***********************************************************/
843:              void AD_Init() 
844:              {
845:              	/*********** ADCON0 ****************************
846:              		Bit7~Bit6  ADCS<1:0>:  AD转换时钟选择位。
847:              			00=  F HSI /16
848:              			01=  F HSI /32
849:              			10=  F HSI /64
850:              			11=  F HSI /128
851:              		Bit5~Bit2  CHS<3:0>:  模拟通道选择位。与ADCON1寄存器CHS4组合CHS<3:0>
852:              			CHS<4:0>: 
853:              			00000=  AN0
854:              			00001=  AN1
855:              			00010=  AN2
856:              			00011=  AN3
857:              			00100=  AN4
858:              			00101=  AN5
859:              			00110=  保留
860:              			00111=  保留
861:              			01000=  AN8
862:              			… 
863:              			01101=  AN13
864:              			01110=  AN14
865:              			01111=  AN15
866:              			11111=  1.2V（固定参考电压）
867:              			其他=  保留
868:              		Bit1  GO/DONE: AD转换状态位。
869:              			1=  AD转换正在进行。将该位置1启动AD转换。当AD转换完成以后，该位由硬件自动清零。
870:              				当GO/DONE位从1变0或ADIF从0变1时，需至少等待两个TAD时间，才能再次启动AD转换。
871:              			0=  AD转换完成/或不在进行中。
872:              		Bit0  ADON:  ADC使能位。
873:              			1=  使能ADC；
874:              			0=  禁止ADC，不消耗工作电流。
875:              	*********************************************/
876:              	ADCON0 = 0X41;		//ADON开启，AD采样时间选为FSYS/16
  05D2    3041    LDIA	0x41
  05D3    1683    SETB	0x3,5
  05D4    0095    LD	0x15,A
877:              	
878:              	/*********** ADCON1 ****************************
879:              		Bit7  ADFM:  AD转换结果格式选择位；
880:              			1=  右对齐；
881:              			0=  左对齐。
882:              		Bit6  CHS4:  通道选择位
883:              		Bit5~Bit3  未用 
884:              		Bit2  LDO_EN:  内部参考电压使能位。
885:              			1=  使能ADC内部LDO参考电压；
886:              				当选择内部LDO作参考电压时，ADC最大有效精度为8位。
887:              			0=  VDD作为ADC参考电压。
888:              		Bit1~Bit0  LDO_SEL<1:0>:  参考电压选择位
889:              			0X=  2.0V
890:              			10=  2.4V
891:              			11=  3.0V
892:              	*********************************************/
893:              	ADCON1 = 0;
  05D5    0196    CLR	0x16
894:              	ANSEL0 = 0X1D;	
  05D6    301D    LDIA	0x1D
  05D7    0093    LD	0x13,A
  05D8    0008    RET
895:              }
896:              
897:              
898:              void chrgPwmInit()
899:              {
900:              		PWMCON1 = 0B00000000;	//PWM选择A组，死区2禁止，死区1使能，死区时钟源为Fosc/4
901:              		
902:              		PWMTH = 0X00;			//周期选择为0FF，则周期为（255+1）*1/8M，周期的时钟分频在PWMCON0选择
903:              		PWMTL = 100;			//PWM 周期=[PWMT+1]*Tosc*(CLKDIV 分频值)
904:              		
905:              	
906:              		
907:              		PWMD01H = 0;			//配置PWM1,PWM2的占空比，该值不能超过周期，否者为100%输出
  05B5    25BC    CALL	0x5BC
908:              		PWMD0L = 1;			//互补模式，PWM1的占空比与PWM0互补，和设置值无关
  05B6    3001    LDIA	0x1
  05B7    0099    LD	0x19,A
909:              		PWM01DT = 0X00;			//死区设为2uS，计算为（3+1）*1/8M*4
  05B8    019F    CLR	0x1F
910:              		
911:              		PWMCON0 = 0X01;			//打开PWM0 分频比为1
  05B9    0095    LD	0x15,A
912:              		PWMCON2 =0X00;			//PWM4输出反向
  05BA    019D    CLR	0x1D
  05BB    0008    RET
913:              }
914:              
915:              void chrgPwmStop()
916:              {
917:              	PWMCON0 &= 0xFE;	//关闭PWM0
  05E2    1015    CLRB	0x15,0
918:              	RB0 = 0;
  05E3    1006    CLRB	0x6,0
  05E4    0008    RET
919:              }
920:              
921:              void pwmInit()
922:              {
923:              		PWMCON1 = 0B00000000;	//PWM选择A组，死区2禁止，死区1使能，死区时钟源为Fosc/4
924:              		PWMTH = 0X00;			//周期选择为0FF，则周期为（255+1）*1/8M，周期的时钟分频在PWMCON0选择
925:              		PWMTL = 100;			//PWM 周期=[PWMT+1]*Tosc*(CLKDIV 分频值)
926:              		
927:              		
928:              		PWMD01H = 0;			//配置PWM1,PWM2的占空比，该值不能超过周期，否者为100%输出
  05CA    25BC    CALL	0x5BC
929:              		PWMD1L = 50;			//互补模式，PWM1的占空比与PWM0互补，和设置值无关
  05CB    3032    LDIA	0x32
  05CC    009A    LD	0x1A,A
930:              		PWM01DT = 0X00;			//死区设为2uS，计算为（3+1）*1/8M*4
  05CD    019F    CLR	0x1F
931:              
932:              		PWMCON0 = 0X62;			//打开PWM1 分频比为8
  05CE    3062    LDIA	0x62
  05CF    0095    LD	0x15,A
933:              		PWMCON2 =0X00;			//PWM4输出反向
  05D0    019D    CLR	0x1D
  05D1    0008    RET
934:              }
935:              
936:              void pwmStop()
937:              {
938:              	PWMCON0 &= 0XFD;
  05DF    1095    CLRB	0x15,1
939:              	RB1 = 0;
  05E0    1086    CLRB	0x6,1
  05E1    0008    RET
940:              }

  0298    3003    LDIA	0x3
  0299    0233    SUBA	0x33
  029A    302B    LDIA	0x2B
  029B    1903    SZB	0x3,2
  029C    0232    SUBA	0x32
  029D    1803    SZB	0x3,0
  029E    2AAE    JP	0x2AE
  029F    0832    LD	A,0x32
  02A0    0277    SUBA	0x77
  02A1    00F4    LD	0x74,A
  02A2    0833    LD	A,0x33
  02A3    1C03    SNZB	0x3,0
  02A4    0A33    INCA	0x33
  02A5    0278    SUBA	0x78
  02A6    00F5    LD	0x75,A
  02A7    3003    LDIA	0x3
  02A8    0275    SUBA	0x75
  02A9    302B    LDIA	0x2B
  02AA    1903    SZB	0x3,2
  02AB    0274    SUBA	0x74
  02AC    1C03    SNZB	0x3,0
  02AD    2AB7    JP	0x2B7
775:              	    	{
776:              	    		//有一节电池已经满了
777:              	    		if(++countHalfFull > 250)
  02AE    30FB    LDIA	0xFB
  02AF    0ACF    INCR	0x4F
  02B0    024F    SUBA	0x4F
  02B1    1C03    SNZB	0x3,0
  02B2    0008    RET

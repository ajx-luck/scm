943:              /***********************************************
944:              函数名称：Sleep_Mode
945:              函数功能：进入休眠模式
946:              入口参数：无
947:              出口参数：无
948:              备注：
949:              ************************************************/
950:              void Sleep_Mode()
951:              {
952:              	INTCON = 0;		
  041A    018B    CLR	0xB
953:              	
954:              	OPTION_REG = 0;
  041B    0181    CLR	0x1
955:              
956:              	TRISA = 0x1F; 		//关闭所有输出，RA0口做唤醒输入
  041C    301F    LDIA	0x1F
  041D    1683    SETB	0x3,5
  041E    0085    LD	0x5,A
957:              	WPUA  = 0B00000000;			//RA0 开上拉电阻
  041F    0188    CLR	0x8
958:              	PORTA = 0x00;
  0420    0186    CLR	0x6
959:              	TRISB = 0B00000100;			//关闭所有输出，RB3口做唤醒输入
  0421    3004    LDIA	0x4
  0422    1283    CLRB	0x3,5
  0423    0085    LD	0x5,A
960:              	PORTB = 0B00000000;
  0424    0186    CLR	0x6
961:              	WPUB  = 0B00000100;			//RB2 开上拉电阻
  0425    0088    LD	0x8,A
962:                 			
963:                 	ADCON0 = 0;					//关闭所有模块
  0426    1683    SETB	0x3,5
  0427    0195    CLR	0x15
964:              	ADCON1 = 0;
  0428    0196    CLR	0x16
965:              	
966:              	PWMCON0 = 0;
  0429    1283    CLRB	0x3,5
  042A    0195    CLR	0x15
967:              		
968:              	OSCCON = 0X70;				//配置振荡为8M,关闭WDT，需注意芯片工程选项里WDT必须选为DISABLE,否则无法软件关掉WDT
  042B    3070    LDIA	0x70
  042C    0094    LD	0x14,A
969:              	
970:              	IOCA = 0B00000010;			//允许RA1的IO电平变化中断
  042D    3002    LDIA	0x2
  042E    1683    SETB	0x3,5
  042F    0089    LD	0x9,A
971:              	IOCB = 0B00000100;			//允许RB3的IO口电平变化中断
  0430    3004    LDIA	0x4
  0431    1283    CLRB	0x3,5
  0432    0089    LD	0x9,A
972:              	
973:              	RAIE = 1;					//允许PORTA的IO电平变化中断
  0433    158E    SETB	0xE,3
974:              	PEIE = 1;					//要用RORTA中断唤醒，则PEIE必须设为1
  0434    170B    SETB	0xB,6
975:              	RBIE = 1;					//允许PORTB电平变化中断
  0435    158B    SETB	0xB,3
976:              	GIE = 0;					//唤醒后执行SLEEP后程序;
  0436    138B    CLRB	0xB,7
977:              	
978:              	PIE1 &= 0X08;				//关闭不需要的中断
  0437    3008    LDIA	0x8
  0438    058E    ANDR	0xE
979:              	PIR1 = 0;					//必须清不需要的中断标志位
  0439    018D    CLR	0xD
980:              	INTCON &= 0XC8;				//必须清不需要的中断标志位
  043A    30C8    LDIA	0xC8
  043B    058B    ANDR	0xB
981:              
982:              	PORTA;						//读PORTA值并锁存,用电平变化中断必须执行这一步
  043C    1683    SETB	0x3,5
  043D    0806    LD	A,0x6
983:              	RAIF = 0;					//清PORTA中断标志位
  043E    1283    CLRB	0x3,5
  043F    118D    CLRB	0xD,3
984:              	PORTB;						//读PORTB值并锁存	
  0440    0806    LD	A,0x6
985:              	RBIF = 0;					//清PORTB中断标志位		
  0441    100B    CLRB	0xB,0
  0442    0064    CLRWDT
  0443    0063    STOP
  0444    0000    NOP
  0445    0064    CLRWDT
  0446    0000    NOP
  0447    0000    NOP
  0448    0000    NOP
  0449    0000    NOP
  044A    0000    NOP
986:              	asm("clrwdt");
987:              
988:              	asm("sleep");				//进入休眠模式
989:              	
990:              	asm("nop");
991:              	asm("clrwdt");
992:              	asm("nop");
993:              	asm("nop");
994:              	asm("nop");
995:              	asm("nop");
996:              	asm("nop");
997:              	if(RAIF)  RAIF = 0;			//清中断标志
  044B    1283    CLRB	0x3,5
  044C    198D    SZB	0xD,3
  044D    118D    CLRB	0xD,3
998:              	if(RBIF)  RBIF = 0;			//清中断标志
  044E    180B    SZB	0xB,0
  044F    100B    CLRB	0xB,0
999:              	if(TMR2IF) TMR2IF = 0;
  0450    188D    SZB	0xD,1
  0451    108D    CLRB	0xD,1
1000:             	IOCA = 0B00000000;			//允许RA1的IO电平变化中断
  0452    1683    SETB	0x3,5
  0453    0189    CLR	0x9
1001:             	IOCB = 0B00000000;			//允许RB3的IO口电平变化中断
  0454    1283    CLRB	0x3,5
  0455    0189    CLR	0x9
1002:             	Init_System();
  0456    2521    CALL	0x521
1003:             	AD_Init();
  0457    2DD2    JP	0x5D2
1004:             }

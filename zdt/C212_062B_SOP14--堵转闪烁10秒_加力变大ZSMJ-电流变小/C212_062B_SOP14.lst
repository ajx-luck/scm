1007:             
1008:             /**********************************************************
1009:             函数名称：AD_Sample
1010:             函数功能：AD检测
1011:             入口参数：adch - 检测通道
1012:             出口参数：无
1013:             备    注：采样通道需自行设置为输入口
1014:             	      采样10次,取中间八次的平均值为采样结果存于adresult中
1015:             
1016:             	      adch 为输入AD通道 0-15，31
1017:                          31  检测内部1.2V
1018:             	
1019:              		  adldo =5,开启内部LDO 2V 作为ADC 参考
1020:              		  adldo =6,开启内部LDO 2.4V 作为ADC 参考
1021:             		  adldo =7,开启内部LDO 3V 作为ADC 参考
1022:              		  adldo =0,VDD 作为ADC 参考
1023:              		  AD转换结果左对齐
1024:              		  ADC参考电压从VDD切换到LDO时需要延时100us以上，才能进行AD转换
1025:             **********************************************************/
1026:             unsigned char ADC_Sample(unsigned char adch, unsigned char adldo) 
  012D    1283    CLRB	0x3,5
  012E    00DC    LD	0x5C,A
1027:             {
1028:             	volatile unsigned long adsum = 0;
1029:             	volatile unsigned int admin = 0, admax = 0;
  012F    2208    CALL	0x208
1030:             	volatile unsigned int ad_temp = 0;
  0130    01E6    CLR	0x66
  0131    01E7    CLR	0x67
1031:             
1032:             	if ((!LDO_EN) && (adldo & 0x04) ) 
  0132    1683    SETB	0x3,5
  0133    1D16    SNZB	0x16,2
  0134    1D73    SNZB	0x73,2
  0135    293F    JP	0x13F
1033:             	{
1034:             								//如果AD参考从VDD换到内部LDO，需要延时100US以上
1035:             		ADCON1 = adldo;			//左对齐,AD值取12位
  0136    0873    LD	A,0x73
  0137    0096    LD	0x16,A
1036:             		__delay_us(100);		//IDE内置延时函数，延时100us
  0138    3084    LDIA	0x84
  0139    1283    CLRB	0x3,5
  013A    00D7    LD	0x57,A
  013B    0BD7    SZDECR	0x57
  013C    293B    JP	0x13B
  013D    293E    JP	0x13E
1037:             	} 
  013E    2941    JP	0x141
1038:             	else
1039:             		ADCON1 = adldo;			//如果ADCON1.7(ADFM)=1为右对齐，,AD值取10位
  013F    0873    LD	A,0x73
  0140    0096    LD	0x16,A
1040:             
1041:             	if(adch & 0x10) 
  0141    1283    CLRB	0x3,5
  0142    1E5C    SNZB	0x5C,4
  0143    2949    JP	0x149
1042:             	{
1043:             		CHS4 = 1;
  0144    1683    SETB	0x3,5
  0145    1716    SETB	0x16,6
1044:             		adch &= 0x0f;
  0146    300F    LDIA	0xF
  0147    1283    CLRB	0x3,5
  0148    05DC    ANDR	0x5C
1045:             	}
1046:             	unsigned char i = 0;
1047:             	for (i = 0; i < 10; i++) 
  0149    01DD    CLR	0x5D
1048:             	{
1049:             		ADCON0 = (unsigned char)(0X41 | (adch << 2));	//16分频，如果主频为16M，则必须选16分频或以上
  014A    085C    LD	A,0x5C
  014B    00D7    LD	0x57,A

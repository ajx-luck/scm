  053F    0088    LD	0x8,A
829:              
830:              	TRISA = 0x1F;				//配置IO状态，0为输出，1为输入
  0540    301F    LDIA	0x1F
  0541    1683    SETB	0x3,5
  0542    0085    LD	0x5,A
831:              	TRISB = 0B00000100;
  0543    3004    LDIA	0x4
  0544    1283    CLRB	0x3,5
  0545    0085    LD	0x5,A
832:              
833:              	PORTA = 0X00;
  0546    1683    SETB	0x3,5
  0547    0186    CLR	0x6
834:              	PORTB = 0X00;
  0548    1283    CLRB	0x3,5
  0549    0186    CLR	0x6
835:              

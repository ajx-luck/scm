  0433    0085    LD	0x5,A
972:              	PORTB = 0B00000000;
  0434    0186    CLR	0x6
973:              	WPUB  = 0B00000100;			//RB2 开上拉电阻
  0435    0088    LD	0x8,A
974:                 			
975:                 	ADCON0 = 0;					//关闭所有模块
  0436    1683    SETB	0x3,5
  0437    0195    CLR	0x15
976:              	ADCON1 = 0;
  0438    0196    CLR	0x16
977:              	
978:              	PWMCON0 = 0;
  0439    1283    CLRB	0x3,5
  043A    0195    CLR	0x15
979:              		
980:              	OSCCON = 0X70;				//配置振荡为8M,关闭WDT，需注意芯片工程选项里WDT必须选为DISABLE,否则无法软件关掉WDT
  043B    3070    LDIA	0x70
  043C    0094    LD	0x14,A
981:              	
982:              	IOCA = 0B00000010;			//允许RA1的IO电平变化中断
  043D    3002    LDIA	0x2
  043E    1683    SETB	0x3,5
  043F    0089    LD	0x9,A
983:              	IOCB = 0B00000100;			//允许RB3的IO口电平变化中断
  0440    3004    LDIA	0x4
  0441    1283    CLRB	0x3,5
  0442    0089    LD	0x9,A
984:              	
985:              	RAIE = 1;					//允许PORTA的IO电平变化中断
  0443    158E    SETB	0xE,3
986:              	PEIE = 1;					//要用RORTA中断唤醒，则PEIE必须设为1
  0444    170B    SETB	0xB,6
987:              	RBIE = 1;					//允许PORTB电平变化中断
  0445    158B    SETB	0xB,3

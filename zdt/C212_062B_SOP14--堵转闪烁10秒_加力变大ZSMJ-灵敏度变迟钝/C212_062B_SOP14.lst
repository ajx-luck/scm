846:              /***********************************************************
847:              中断服务函数
848:              函数名称：AD_Init()
849:              函数功能：AD初始化处理函数
850:              入口参数：
851:              出口参数：
852:              备    注：第一次打开AD允许位ADON，需延时20uS以上才能进入AD采样
853:              			如后继程序不关闭ADON，则不需要延时
854:              ***********************************************************/
855:              void AD_Init() 
856:              {
857:              	/*********** ADCON0 ****************************
858:              		Bit7~Bit6  ADCS<1:0>:  AD转换时钟选择位。
859:              			00=  F HSI /16
860:              			01=  F HSI /32
861:              			10=  F HSI /64
862:              			11=  F HSI /128
863:              		Bit5~Bit2  CHS<3:0>:  模拟通道选择位。与ADCON1寄存器CHS4组合CHS<3:0>
864:              			CHS<4:0>: 
865:              			00000=  AN0
866:              			00001=  AN1
867:              			00010=  AN2
868:              			00011=  AN3
869:              			00100=  AN4
870:              			00101=  AN5
871:              			00110=  保留
872:              			00111=  保留
873:              			01000=  AN8
874:              			… 
875:              			01101=  AN13
876:              			01110=  AN14
877:              			01111=  AN15
878:              			11111=  1.2V（固定参考电压）
879:              			其他=  保留
880:              		Bit1  GO/DONE: AD转换状态位。
881:              			1=  AD转换正在进行。将该位置1启动AD转换。当AD转换完成以后，该位由硬件自动清零。
882:              				当GO/DONE位从1变0或ADIF从0变1时，需至少等待两个TAD时间，才能再次启动AD转换。
883:              			0=  AD转换完成/或不在进行中。
884:              		Bit0  ADON:  ADC使能位。
885:              			1=  使能ADC；
886:              			0=  禁止ADC，不消耗工作电流。
887:              	*********************************************/
888:              	ADCON0 = 0X41;		//ADON开启，AD采样时间选为FSYS/16
  05E2    3041    LDIA	0x41
  05E3    1683    SETB	0x3,5
  05E4    0095    LD	0x15,A
889:              	
890:              	/*********** ADCON1 ****************************
891:              		Bit7  ADFM:  AD转换结果格式选择位；
892:              			1=  右对齐；
893:              			0=  左对齐。
894:              		Bit6  CHS4:  通道选择位
895:              		Bit5~Bit3  未用 
896:              		Bit2  LDO_EN:  内部参考电压使能位。
897:              			1=  使能ADC内部LDO参考电压；
898:              				当选择内部LDO作参考电压时，ADC最大有效精度为8位。
899:              			0=  VDD作为ADC参考电压。
900:              		Bit1~Bit0  LDO_SEL<1:0>:  参考电压选择位
901:              			0X=  2.0V
902:              			10=  2.4V
903:              			11=  3.0V
904:              	*********************************************/
905:              	ADCON1 = 0;
  05E5    0196    CLR	0x16
906:              	ANSEL0 = 0X1D;	
  05E6    301D    LDIA	0x1D
  05E7    0093    LD	0x13,A
  05E8    0008    RET
907:              }
908:              
909:              
910:              void chrgPwmInit()
911:              {
912:              		PWMCON1 = 0B00000000;	//PWM选择A组，死区2禁止，死区1使能，死区时钟源为Fosc/4
913:              		
914:              		PWMTH = 0X00;			//周期选择为0FF，则周期为（255+1）*1/8M，周期的时钟分频在PWMCON0选择
915:              		PWMTL = 100;			//PWM 周期=[PWMT+1]*Tosc*(CLKDIV 分频值)
916:              		
917:              	
918:              		
919:              		PWMD01H = 0;			//配置PWM1,PWM2的占空比，该值不能超过周期，否者为100%输出
  05C5    25CC    CALL	0x5CC
920:              		PWMD0L = 1;			//互补模式，PWM1的占空比与PWM0互补，和设置值无关
  05C6    3001    LDIA	0x1
  05C7    0099    LD	0x19,A
921:              		PWM01DT = 0X00;			//死区设为2uS，计算为（3+1）*1/8M*4
  05C8    019F    CLR	0x1F
922:              		
923:              		PWMCON0 = 0X01;			//打开PWM0 分频比为1
  05C9    0095    LD	0x15,A
924:              		PWMCON2 =0X00;			//PWM4输出反向
  05CA    019D    CLR	0x1D
  05CB    0008    RET
925:              }
926:              
927:              void chrgPwmStop()
928:              {
929:              	PWMCON0 &= 0xFE;	//关闭PWM0
  05F2    1015    CLRB	0x15,0
930:              	RB0 = 0;
  05F3    1006    CLRB	0x6,0
  05F4    0008    RET
931:              }
932:              
933:              void pwmInit()
934:              {
935:              		PWMCON1 = 0B00000000;	//PWM选择A组，死区2禁止，死区1使能，死区时钟源为Fosc/4
936:              		PWMTH = 0X00;			//周期选择为0FF，则周期为（255+1）*1/8M，周期的时钟分频在PWMCON0选择
937:              		PWMTL = 100;			//PWM 周期=[PWMT+1]*Tosc*(CLKDIV 分频值)
938:              		
939:              		
940:              		PWMD01H = 0;			//配置PWM1,PWM2的占空比，该值不能超过周期，否者为100%输出
  05DA    25CC    CALL	0x5CC
941:              		PWMD1L = 50;			//互补模式，PWM1的占空比与PWM0互补，和设置值无关
  05DB    3032    LDIA	0x32
  05DC    009A    LD	0x1A,A
942:              		PWM01DT = 0X00;			//死区设为2uS，计算为（3+1）*1/8M*4
  05DD    019F    CLR	0x1F
943:              
944:              		PWMCON0 = 0X62;			//打开PWM1 分频比为8
  05DE    3062    LDIA	0x62
  05DF    0095    LD	0x15,A
945:              		PWMCON2 =0X00;			//PWM4输出反向
  05E0    019D    CLR	0x1D
  05E1    0008    RET
946:              }
947:              
948:              void pwmStop()
949:              {
950:              	PWMCON0 &= 0XFD;
  05EF    1095    CLRB	0x15,1
951:              	RB1 = 0;
  05F0    1086    CLRB	0x6,1
  05F1    0008    RET
952:              }

821:              	asm("clrwdt");
822:              	OPTION_REG = 0;					//预分频给TMR0 ，Timer0使用内部时钟Focs/4，预分频比为1:2
  0533    1283    CLRB	0x3,5
  0534    0181    CLR	0x1
  0535    0064    CLRWDT
823:              	asm("clrwdt");
824:              	OSCCON = 0X72;					//内部振荡器8M
  0536    3072    LDIA	0x72
  0537    1283    CLRB	0x3,5
  0538    0094    LD	0x14,A
825:              
826:              	WPUA = 0B00000000;				//配置上拉，1为使能上拉
  0539    1683    SETB	0x3,5
